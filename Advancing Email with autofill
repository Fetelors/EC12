function render() {
  // Tabs
  document.getElementById('stepTabs').innerHTML = STEPS.map(s => {
    const hasOD = s.who==='EC' && Object.keys(DEADLINE).some(f => !S[f] && DEADLINE[f] < s.n);
    return `<div class="step-tab ${s.who==='EC'?'ec-step':'tm-step'} ${S.step===s.n?'active-tab':''}" onclick="goStep(${s.n})" title="${s.title}">
      ${hasOD ? '<span class="tab-alert" style="display:block"></span>' : ''}
      <span class="step-tab-badge">${s.who}</span>
      <span class="step-tab-num">${s.n}</span>
    </div>`;
  }).join('');

  // Ctx bar
  const st = STEPS[S.step-1];
  const catchup = st.who==='EC' && hasCatchup(S.step);
  const odCount = Object.keys(DEADLINE).filter(f => !S[f] && DEADLINE[f] < S.step).length;
  document.getElementById('ctxBar').innerHTML = `
    <div class="ctx-item"><strong>${S.artistName||'—'}</strong></div>
    <span class="ctx-sep">·</span>
    <div class="ctx-item">Step ${S.step}: <strong>${st.title}</strong></div>
    <span class="ctx-sep">·</span>
    <div class="ctx-item">Advances: <span class="ctx-badge ${st.who==='EC'?'ec':'tm'}">${st.who}</span></div>
    ${catchup ? `<span class="ctx-sep">·</span><div class="ctx-item"><span class="ctx-badge catchup">⚠ ${odCount} overdue block${odCount!==1?'s':''} pulled in</span></div>` : ''}
  `;

  // Output
  const area = document.getElementById('outputArea');
  const escH = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

  if (st.who === 'EC') {
    let result;
    if      (S.step===1) result = genStep1();
    else if (S.step===3) result = genStep3();
    else if (S.step===5) result = genStep5();
    else if (S.step===7) result = genStep7();
    else result = {body:'// Template coming soon.', att:[]};

    const od   = Object.keys(DEADLINE).filter(f => overdue(f));
    const due  = Object.keys(DEADLINE).filter(f => !S[f] && DEADLINE[f] === S.step);

    const catchupHtml = (catchup && od.length) ? `
      <div class="catchup-notice">
        <span style="font-size:14px;flex-shrink:0;margin-top:1px">⚠️</span>
        <div class="catchup-notice-text">
          <strong>${od.length} overdue block${od.length!==1?'s':''} included from earlier steps.</strong>
          The subject line signals a full catch-up email to the TM.
        </div>
      </div>
      <div class="blocks-summary">
        ${od.map(f=>`<span class="block-chip overdue">${BLOCK_LABELS[f]||f}</span>`).join('')}
        ${due.map(f=>`<span class="block-chip new">${BLOCK_LABELS[f]||f}</span>`).join('')}
      </div>` : '';

    const attHtml = result.att.length
      ? `<div class="attach-row">${result.att.map(a=>`<span class="attach-tag">📎 ${a}</span>`).join('')}</div>` : '';

    area.innerHTML = `
      <div class="out-hd">
        <div>
          <div class="out-step-title">${st.title}</div>
          <div class="out-step-meta">EC advances this step &nbsp;·&nbsp; Updates live as you fill the form</div>
        </div>
        <button class="btn btn-copy" id="copyBtn" onclick="copyEmail()">Copy Email</button>
      </div>
      ${catchupHtml}
      <div class="subject-bar">
        <span class="subject-label">Subject</span>
        <span class="subject-text">${escH(subject(S.step))}</span>
      </div>
      ${attHtml}
      <div class="email-body" id="emailBody">${escH(result.body)}</div>`;

  } else {
    const items = tmItems(S.step);
    area.innerHTML = `
      <div class="out-hd">
        <div>
          <div class="out-step-title">${st.title}</div>
          <div class="out-step-meta">Tour Manager advances this step &nbsp;·&nbsp; Awaiting info from TM</div>
        </div>
        <button class="btn btn-chase" id="chaseBtn" onclick="copyChase()">Copy Chase Email</button>
      </div>
      <div class="tm-card">
        <div class="tm-card-hd"><span class="tm-card-icon">📬</span><span class="tm-card-title">Information needed from Tour Manager — Step ${S.step}</span></div>
        <div class="tm-card-body">${items.map(item=>`
          <div class="tm-item">
            <span class="tm-item-icon">${item.i}</span>
            <div class="tm-item-body">
              <div class="tm-item-title">${item.t}</div>
              <div class="tm-item-desc">${item.d}</div>
            </div>
          </div>`).join('')}
        </div>
      </div>`;
  }
}

function goStep(n) { S.step = n; render(); }

function copyEmail() {
  const el = document.getElementById('emailBody');
  if (!el) return;
  navigator.clipboard.writeText(`Subject: ${subject(S.step)}\n\n${el.innerText}`).then(() => {
    const btn = document.getElementById('copyBtn');
    if (!btn) return;
    btn.textContent = '✓ Copied!'; btn.classList.add('ok');
    setTimeout(() => { btn.textContent = 'Copy Email'; btn.classList.remove('ok'); }, 2200);
  });
}

function copyChase() {
  const chase = `Hi ${TM()},\n\nJust a quick follow-up on the Electric Castle 2025 advancing for ${A()} — we're at Step ${S.step} and still waiting on the items above.\n\nCould you please send these across when you get a chance? Happy to jump on a call if easier.\n\nThanks,\n${LEAD()}\nElectric Castle Hospitality Team`;
  navigator.clipboard.writeText(chase).then(() => {
    const btn = document.getElementById('chaseBtn');
    if (!btn) return;
    btn.textContent = '✓ Copied!'; btn.classList.add('ok');
    setTimeout(() => { btn.textContent = 'Copy Chase Email'; btn.classList.remove('ok'); }, 2200);
  });
}

