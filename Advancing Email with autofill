<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EC Hospitality // Email Generator</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root {
  --primary:         #1A3A2A;
  --primary-mid:     #2D5A40;
  --primary-light:   #4A8C6B;
  --primary-faint:   #EAF4EE;
  --gold:            #9C6E1A;
  --gold-light:      #FEF6E4;
  --gold-mid:        #7A540E;
  --cream:           #FDF8F0;
  --cream-dark:      #EDE3D0;
  --red:             #C0392B;
  --red-light:       #FDEDEC;
  --state-good:      #059669;
  --text:            #1A1A1A;
  --text-mid:        #4A4A4A;
  --text-soft:       #717171;
  --radius:          10px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }
body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); display: flex; flex-direction: column; height: 100vh; }

/* HEADER */
.app-header { background: var(--primary); padding: 13px 22px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; gap: 16px; }
.header-brand { display: flex; align-items: baseline; gap: 10px; }
.header-title  { font-family: 'Playfair Display', serif; font-size: 18px; color: white; }
.header-div    { color: rgba(255,255,255,0.25); }
.header-sub    { font-size: 11px; color: rgba(255,255,255,0.42); font-weight: 400; }
.header-artist { font-size: 12.5px; font-weight: 600; color: white; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.18); padding: 4px 13px; border-radius: 20px; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex-shrink: 0; }
.header-artist.empty { color: rgba(255,255,255,0.3); font-weight: 400; font-style: italic; font-size: 11.5px; }
.header-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
.btn-autofill {
  display: flex; align-items: center; gap: 6px;
  padding: 5px 13px; border-radius: 20px; border: 1.5px solid rgba(255,255,255,0.25);
  background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.85);
  font-family: 'DM Sans', sans-serif; font-size: 11.5px; font-weight: 600;
  cursor: pointer; transition: all 0.15s; white-space: nowrap;
}
.btn-autofill:hover { background: rgba(255,255,255,0.18); border-color: rgba(255,255,255,0.4); color: white; }
.btn-autofill .scenario-pip {
  width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
  transition: background 0.2s;
}
.btn-autofill .btn-autofill-label { font-size: 9px; opacity: 0.6; margin-left: 2px; }

/* LAYOUT */
.app-body { display: flex; flex: 1; overflow: hidden; }

/* SIDEBAR */
.sidebar { width: 355px; min-width: 290px; background: white; border-right: 2px solid var(--cream-dark); overflow-y: auto; flex-shrink: 0; }
.sidebar-section { border-bottom: 1px solid var(--cream-dark); }
.sidebar-section-hd { padding: 10px 15px; background: var(--cream); display: flex; align-items: center; justify-content: space-between; cursor: pointer; user-select: none; transition: background 0.15s; }
.sidebar-section-hd:hover { background: var(--cream-dark); }
.sidebar-section-title { font-family: 'Playfair Display', serif; font-size: 12px; color: var(--primary); }
.sshd-right { display: flex; align-items: center; gap: 7px; }
.sidebar-section-arrow { font-size: 9px; color: var(--text-soft); }
.sec-count { font-size: 9px; font-weight: 700; padding: 1px 6px; border-radius: 8px; background: var(--red-light); color: var(--red); display: none; }
.sec-count.show { display: inline-block; }
.sidebar-section-body { padding: 12px 15px; display: flex; flex-direction: column; gap: 8px; }
.sidebar-section-body.closed { display: none; }

/* FORM */
label.field-label { font-size: 9.5px; font-weight: 600; color: var(--text-soft); letter-spacing: 0.5px; text-transform: uppercase; display: block; margin-bottom: 3px; }
input[type="text"], input[type="date"], input[type="email"], input[type="number"], select, textarea { width: 100%; background: var(--cream); border: 1.5px solid var(--cream-dark); border-radius: 7px; padding: 6px 9px; font-family: 'DM Sans', sans-serif; font-size: 12.5px; color: var(--text); outline: none; transition: border-color 0.15s, background 0.15s; }
input:focus, select:focus, textarea:focus { border-color: var(--primary-light); background: white; }
textarea { resize: vertical; min-height: 50px; line-height: 1.5; }
.row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }

/* HOTEL TIER */
.hotel-tier { background: var(--cream); border: 1.5px solid var(--cream-dark); border-radius: 8px; padding: 8px 10px; display: flex; flex-direction: column; gap: 7px; transition: opacity 0.2s; }
.hotel-tier.dim { opacity: 0.4; }
.hotel-tier-hd { display: flex; align-items: center; justify-content: space-between; }
.hotel-tier-label { font-size: 11px; font-weight: 600; color: var(--primary); }
.hotel-tier-stars { font-size: 10px; color: var(--gold); letter-spacing: 1px; }

/* TRAVEL */
.travel-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; }
.travel-btn { padding: 6px 7px; background: var(--cream); border: 2px solid var(--cream-dark); border-radius: 7px; cursor: pointer; text-align: center; font-size: 11px; font-weight: 500; transition: all 0.15s; user-select: none; color: var(--text-mid); }
.travel-btn:hover { border-color: var(--primary-light); color: var(--primary); }
.travel-btn.on { background: var(--primary-faint); border-color: var(--primary-light); color: var(--primary); font-weight: 600; }

/* CHECKBOXES */
.chk-row { display: flex; align-items: flex-start; gap: 7px; cursor: pointer; padding: 3px 0; }
.chk-row input[type="checkbox"] { width: 14px; height: 14px; accent-color: var(--primary); cursor: pointer; flex-shrink: 0; margin-top: 2px; }
.chk-row span { font-size: 11.5px; color: var(--text-mid); line-height: 1.4; user-select: none; }

/* SENT STEP HEADERS */
.sent-step-hd { display: flex; align-items: center; gap: 7px; padding: 5px 0 3px; }
.sent-step-label { font-size: 9px; font-weight: 700; letter-spacing: 0.6px; text-transform: uppercase; padding: 2px 7px; border-radius: 8px; }
.sent-step-label.ec { background: rgba(74,140,107,0.15); color: var(--primary-mid); }
.sent-step-line { flex: 1; height: 1px; background: var(--cream-dark); }
.sent-step-due { font-size: 9px; color: var(--text-soft); font-weight: 500; }

/* OUTPUT */
.output-panel { flex: 1; overflow: hidden; display: flex; flex-direction: column; min-width: 0; }

/* STEP TABS */
.step-tabs { background: var(--primary); display: flex; padding: 0 16px; overflow-x: auto; flex-shrink: 0; scrollbar-width: none; }
.step-tabs::-webkit-scrollbar { display: none; }
.step-tab { padding: 9px 16px 7px; display: flex; flex-direction: column; align-items: center; gap: 2px; cursor: pointer; border-bottom: 3px solid transparent; transition: all 0.15s; flex-shrink: 0; position: relative; }
.step-tab:hover { background: rgba(255,255,255,0.06); }
.step-tab.active-tab { border-bottom-color: #52B788; background: rgba(255,255,255,0.08); }
.step-tab-badge { font-size: 8px; font-weight: 700; letter-spacing: 0.6px; text-transform: uppercase; padding: 1px 5px; border-radius: 3px; }
.ec-step .step-tab-badge { background: rgba(82,183,136,0.25); color: #82D4A8; }
.tm-step .step-tab-badge { background: rgba(184,134,11,0.3); color: #FBBF24; }
.step-tab-num { font-size: 16px; font-weight: 700; color: rgba(255,255,255,0.4); line-height: 1; }
.step-tab.active-tab .step-tab-num { color: white; }
.step-tab:not(.active-tab):hover .step-tab-num { color: rgba(255,255,255,0.65); }
.tab-alert { position: absolute; top: 5px; right: 5px; width: 6px; height: 6px; border-radius: 50%; background: #FF6B6B; display: none; }

/* CTX BAR */
.ctx-bar { background: var(--primary-mid); padding: 6px 19px; display: flex; align-items: center; gap: 9px; flex-shrink: 0; flex-wrap: wrap; }
.ctx-item { font-size: 10.5px; color: rgba(255,255,255,0.55); display: flex; align-items: center; gap: 4px; }
.ctx-item strong { color: white; font-weight: 600; }
.ctx-sep { color: rgba(255,255,255,0.2); font-size: 11px; }
.ctx-badge { font-size: 8.5px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; padding: 2px 7px; border-radius: 10px; }
.ctx-badge.ec { background: rgba(82,183,136,0.3); color: #82D4A8; }
.ctx-badge.tm { background: rgba(251,191,36,0.3); color: #FBBF24; }
.ctx-badge.catchup { background: rgba(255,107,107,0.3); color: #FF9B8E; }

/* OUTPUT AREA */
.output-area { flex: 1; overflow-y: auto; padding: 18px 22px 48px; display: flex; flex-direction: column; gap: 12px; }
.out-hd { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; }
.out-step-title { font-family: 'Playfair Display', serif; font-size: 18px; color: var(--primary); }
.out-step-meta { font-size: 11px; color: var(--text-soft); margin-top: 3px; }

/* CATCHUP NOTICE */
.catchup-notice { background: var(--red-light); border: 1.5px solid #E6B0AA; border-radius: 8px; padding: 9px 13px; display: flex; align-items: flex-start; gap: 8px; }
.catchup-notice-text { font-size: 11.5px; color: var(--red); line-height: 1.5; }
.catchup-notice-text strong { font-weight: 700; }
.blocks-summary { display: flex; flex-wrap: wrap; gap: 5px; }
.block-chip { font-size: 9.5px; font-weight: 600; letter-spacing: 0.3px; padding: 3px 8px; border-radius: 10px; text-transform: uppercase; }
.block-chip.new     { background: var(--primary-faint); color: var(--primary-mid); }
.block-chip.overdue { background: var(--red-light); color: var(--red); }

/* SUBJECT */
.subject-bar { background: var(--primary-faint); border: 1.5px solid var(--primary-light); border-radius: 8px; padding: 8px 13px; display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }
.subject-label { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; color: var(--primary-mid); flex-shrink: 0; }
.subject-text { font-size: 12.5px; color: var(--primary); font-weight: 500; }

/* ATTACHMENTS */
.attach-row { display: flex; gap: 5px; flex-wrap: wrap; }
.attach-tag { display: inline-flex; align-items: center; gap: 4px; font-size: 9.5px; font-weight: 600; padding: 3px 8px; border-radius: 10px; text-transform: uppercase; background: var(--primary-faint); color: var(--primary-mid); }

/* BUTTONS */
.btn { padding: 7px 15px; border-radius: 8px; border: none; font-family: 'DM Sans', sans-serif; font-size: 11.5px; font-weight: 600; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
.btn-copy { background: var(--primary-faint); color: var(--primary); border: 1.5px solid var(--primary-light); }
.btn-copy:hover { background: var(--primary-light); color: white; }
.btn-copy.ok { background: var(--state-good); color: white; border-color: var(--state-good); }
.btn-chase { background: var(--gold-light); color: var(--gold); border: 1.5px solid #D4A83A; }
.btn-chase:hover { background: var(--gold); color: white; }
.btn-chase.ok { background: var(--state-good); color: white; }

/* EMAIL BODY */
.email-body { background: white; border: 2px solid var(--cream-dark); border-radius: var(--radius); padding: 20px 24px; font-size: 13px; line-height: 1.85; color: var(--text); white-space: pre-wrap; font-family: 'DM Sans', sans-serif; }

/* TM CARD */
.tm-card { background: white; border: 2px solid #F3E0A0; border-radius: var(--radius); overflow: hidden; }
.tm-card-hd { background: var(--gold-light); padding: 12px 17px; display: flex; align-items: center; gap: 9px; border-bottom: 1px solid #F0D88A; }
.tm-card-icon { font-size: 16px; }
.tm-card-title { font-family: 'Playfair Display', serif; font-size: 13.5px; color: var(--gold-mid); }
.tm-card-body { padding: 12px 15px; display: flex; flex-direction: column; gap: 7px; }
.tm-item { display: flex; align-items: flex-start; gap: 8px; background: var(--cream); border: 1px solid var(--cream-dark); border-radius: 7px; padding: 7px 9px; }
.tm-item-icon { font-size: 13px; flex-shrink: 0; margin-top: 1px; }
.tm-item-body { display: flex; flex-direction: column; gap: 1px; }
.tm-item-title { font-size: 11.5px; font-weight: 600; color: var(--text); }
.tm-item-desc  { font-size: 11px; color: var(--text-soft); line-height: 1.4; }

::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--cream-dark); border-radius: 10px; }

@media (max-width: 860px) {
  html, body { overflow: auto; height: auto; }
  .app-body { flex-direction: column; }
  .sidebar { width: 100%; border-right: none; border-bottom: 2px solid var(--cream-dark); }
  .output-panel { height: auto; }
  .output-area { overflow-y: visible; }
}
</style>
</head>
<body>

<header class="app-header">
  <div class="header-brand">
    <span class="header-title">EC Hospitality</span>
    <span class="header-div">/</span>
    <span class="header-sub">Email Draft Generator</span>
  </div>
  <div class="header-right">
    <button class="btn-autofill" id="autofillBtn" onclick="autoFill()">
      <span class="scenario-pip" id="scenarioPip"></span>
      Auto-fill
      <span class="btn-autofill-label" id="scenarioLabel"></span>
    </button>
    <div class="header-artist empty" id="headerArtist">No artist entered</div>
  </div>
</header>

<div class="app-body">

<aside class="sidebar">

  <!-- Artist & Contact -->
  <div class="sidebar-section">
    <div class="sidebar-section-hd" onclick="toggleSec('contact')">
      <span class="sidebar-section-title">Artist & Contact</span>
      <div class="sshd-right"><span class="sidebar-section-arrow" id="arr-contact">▼</span></div>
    </div>
    <div class="sidebar-section-body" id="sec-contact">
      <div><label class="field-label">Artist Name</label><input type="text" id="artistName" placeholder="e.g. Fred Again.." oninput="upd()"></div>
      <div class="row2">
        <div><label class="field-label">Advancing Lead</label><input type="text" id="advLead" placeholder="Your name" oninput="upd()"></div>
        <div><label class="field-label">Performance Date</label><input type="date" id="perfDate" oninput="upd()"></div>
      </div>
      <div><label class="field-label">Stage</label><input type="text" id="stageName" placeholder="e.g. Main Stage" oninput="upd()"></div>
      <div><label class="field-label">Tour Manager Name</label><input type="text" id="tmName" placeholder="TM full name" oninput="upd()"></div>
      <div><label class="field-label">TM Email</label><input type="email" id="tmEmail" placeholder="tm@agency.com" oninput="upd()"></div>
      <div><label class="field-label">CC — Monday Artist Item</label><input type="email" id="ccEmail" placeholder="monday+artist@electriccastle.ro" oninput="upd()"></div>
    </div>
  </div>

  <!-- Hotels -->
  <div class="sidebar-section">
    <div class="sidebar-section-hd" onclick="toggleSec('hotels')">
      <span class="sidebar-section-title">Hotel Configuration</span>
      <div class="sshd-right"><span class="sidebar-section-arrow" id="arr-hotels">▼</span></div>
    </div>
    <div class="sidebar-section-body" id="sec-hotels">
      <div class="hotel-tier" id="tier-a">
        <div class="hotel-tier-hd"><span class="hotel-tier-label">A-Party</span><span class="hotel-tier-stars">★★★★★</span></div>
        <div class="row2">
          <div><label class="field-label">Rooms</label><input type="number" id="aCount" value="0" min="0" oninput="upd()"></div>
          <div><label class="field-label">Hotel</label><select id="aHotel" onchange="upd()"><option>Radisson Blu</option><option>Vibre Hotel</option><option>Platinia Hotel</option><option>Other — TBC</option></select></div>
        </div>
        <div class="row2">
          <div><label class="field-label">Check-in</label><input type="date" id="aIn" oninput="upd()"></div>
          <div><label class="field-label">Check-out</label><input type="date" id="aOut" oninput="upd()"></div>
        </div>
      </div>
      <div class="hotel-tier" id="tier-b">
        <div class="hotel-tier-hd"><span class="hotel-tier-label">B-Party</span><span class="hotel-tier-stars">★★★★☆</span></div>
        <div class="row2">
          <div><label class="field-label">Rooms</label><input type="number" id="bCount" value="0" min="0" oninput="upd()"></div>
          <div><label class="field-label">Hotel</label><select id="bHotel" onchange="upd()"><option>Courtyard by Marriott</option><option>Grand Hotel Napoca</option><option>Royal Class Hotel</option><option>Other — TBC</option></select></div>
        </div>
        <div class="row2">
          <div><label class="field-label">Check-in</label><input type="date" id="bIn" oninput="upd()"></div>
          <div><label class="field-label">Check-out</label><input type="date" id="bOut" oninput="upd()"></div>
        </div>
      </div>
      <div class="hotel-tier" id="tier-crew">
        <div class="hotel-tier-hd"><span class="hotel-tier-label">Crew</span><span class="hotel-tier-stars">★★★★</span></div>
        <div class="row2">
          <div><label class="field-label">Rooms</label><input type="number" id="crewCount" value="0" min="0" oninput="upd()"></div>
          <div><label class="field-label">Hotel</label><select id="crewHotel" onchange="upd()"><option>Grand Hotel Napoca</option><option>Courtyard by Marriott</option><option>Royal Class Hotel</option><option>Other — TBC</option></select></div>
        </div>
        <div class="row2">
          <div><label class="field-label">Check-in</label><input type="date" id="crewIn" oninput="upd()"></div>
          <div><label class="field-label">Check-out</label><input type="date" id="crewOut" oninput="upd()"></div>
        </div>
      </div>
      <div class="hotel-tier" id="tier-drivers">
        <div class="hotel-tier-hd"><span class="hotel-tier-label">Drivers / Truck Crew</span><span class="hotel-tier-stars">★★★</span></div>
        <div class="row2">
          <div><label class="field-label">Rooms</label><input type="number" id="drvCount" value="0" min="0" oninput="upd()"></div>
          <div><label class="field-label">Hotel</label><select id="drvHotel" onchange="upd()"><option>Golden Tulip Ana Dome</option><option>Belvedere Hotel</option><option>Other — TBC</option></select></div>
        </div>
      </div>
      <label class="chk-row"><input type="checkbox" id="extraCovered" onchange="upd()"><span>Extra nights covered by festival</span></label>
    </div>
  </div>

  <!-- Travel -->
  <div class="sidebar-section">
    <div class="sidebar-section-hd" onclick="toggleSec('travel')">
      <span class="sidebar-section-title">Travel</span>
      <div class="sshd-right"><span class="sidebar-section-arrow" id="arr-travel">▼</span></div>
    </div>
    <div class="sidebar-section-body" id="sec-travel">
      <div>
        <label class="field-label">Travel Mode</label>
        <div class="travel-grid">
          <div class="travel-btn on" data-mode="flying"      onclick="setTravel('flying')">✈ Flying in</div>
          <div class="travel-btn"    data-mode="nightliner"  onclick="setTravel('nightliner')">🚌 Nightliner</div>
          <div class="travel-btn"    data-mode="selfdriving" onclick="setTravel('selfdriving')">🚗 Self-driving</div>
          <div class="travel-btn"    data-mode="mixed"       onclick="setTravel('mixed')">⇄ Mixed</div>
        </div>
      </div>
      <div id="fld-flying">
        <div class="row2" style="margin-bottom:6px">
          <div><label class="field-label">Flying from</label><input type="text" id="flyFrom" placeholder="e.g. London" oninput="upd()"></div>
          <div><label class="field-label">Airport</label><input type="text" id="flyAirport" value="CLJ" oninput="upd()"></div>
        </div>
        <div class="row2">
          <div><label class="field-label">Approx. arrival</label><input type="date" id="flyArrival" oninput="upd()"></div>
          <div><label class="field-label">Approx. departure</label><input type="date" id="flyDepart" oninput="upd()"></div>
        </div>
      </div>
      <div id="fld-nightliner" style="display:none">
        <div style="margin-bottom:6px"><label class="field-label">Vehicle reg number(s)</label><input type="text" id="nlReg" placeholder="e.g. AB 12 CDE" oninput="upd()"></div>
        <div><label class="field-label">Parking preference</label><input type="text" id="nlParking" placeholder="e.g. artist compound" oninput="upd()"></div>
      </div>
      <div id="fld-selfdriving" style="display:none">
        <div class="row2">
          <div><label class="field-label">Reg number(s)</label><input type="text" id="sdReg" placeholder="e.g. B 123 XYZ" oninput="upd()"></div>
          <div><label class="field-label">Make / model</label><input type="text" id="sdCar" placeholder="e.g. Range Rover" oninput="upd()"></div>
        </div>
      </div>
      <div id="fld-mixed" style="display:none">
        <label class="field-label">Mixed travel — notes</label>
        <textarea id="mixedNotes" placeholder="e.g. Artist flying London, crew on nightliner from Berlin" oninput="upd()"></textarea>
      </div>
    </div>
  </div>

  <!-- Rider -->
  <div class="sidebar-section">
    <div class="sidebar-section-hd" onclick="toggleSec('rider')">
      <span class="sidebar-section-title">Rider & Dietary</span>
      <div class="sshd-right"><span class="sidebar-section-arrow" id="arr-rider">▼</span></div>
    </div>
    <div class="sidebar-section-body" id="sec-rider">
      <label class="chk-row"><input type="checkbox" id="riderRcvd"    onchange="upd()"><span>Rider received</span></label>
      <label class="chk-row"><input type="checkbox" id="riderApproved" onchange="upd()"><span>Rider alternatives approved by TM</span></label>
      <div><label class="field-label">Dietary requirements</label><textarea id="dietaryReqs" placeholder="e.g. 1× vegan, 1× gluten-free" oninput="upd()"></textarea></div>
    </div>
  </div>

  <!-- Already Sent -->
  <div class="sidebar-section">
    <div class="sidebar-section-hd" onclick="toggleSec('sent')">
      <span class="sidebar-section-title">Already Sent</span>
      <div class="sshd-right">
        <span class="sec-count" id="pendingCount"></span>
        <span class="sidebar-section-arrow" id="arr-sent">▼</span>
      </div>
    </div>
    <div class="sidebar-section-body" id="sec-sent">

