      <label class="chk-row"><input type="checkbox" id="hotelDescSent"  onchange="upd()"><span>Hotel options / descriptions shared</span></label>
      <label class="chk-row"><input type="checkbox" id="distancesSent"  onchange="upd()"><span>Distances & durations to site</span></label>
