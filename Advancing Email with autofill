  _autoFillIndex = (_autoFillIndex + 1) % SCENARIOS.length;

  // ── Set text/select/date/number fields ────────────────────────────
  const flds = sc.fields;
  Object.keys(flds).forEach(key => {
    if (key === 'travelMode') return; // handled separately
    const el = document.getElementById(key);
    if (!el) return;
    if (el.type === 'checkbox') el.checked = !!flds[key];
    else el.value = flds[key] ?? '';
  });

  // ── Set travel mode (updates buttons + field visibility) ──────────
  if (flds.travelMode) setTravel(flds.travelMode);

  // ── Reset all sent flags to false first ───────────────────────────
  Object.keys(DEADLINE).forEach(flag => {
    const el = document.getElementById(flag);
    if (el) el.checked = false;
  });
  // Then tick the ones this scenario has sent
  Object.keys(sc.sent).forEach(flag => {
    const el = document.getElementById(flag);
    if (el) el.checked = !!sc.sent[flag];
  });

  // ── Reset other checkboxes ────────────────────────────────────────
  ['extraCovered','riderRcvd','riderApproved','guestListReq','pressScheduled','mealTimesConf'].forEach(f => {
    const el = document.getElementById(f);
    if (el) el.checked = !!(flds[f]);
