  L.push(section('HOTEL SUMMARY', activeTiers().map(t => hotelBlock(t,true)).join('\n\n')));

  if (S.drDetails) {
    L.push(section('DRESSING ROOM', `${S.drDetails}\n\nYour Angel will take you there on arrival.`));
