<script>
// ══════════════════════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════════════════════
let S = {
  step: 1,
  artistName:'', advLead:'', tmName:'', tmEmail:'', ccEmail:'', perfDate:'', stageName:'',
  aCount:0, aHotel:'Radisson Blu', aIn:'', aOut:'',
  bCount:0, bHotel:'Courtyard by Marriott', bIn:'', bOut:'',
  crewCount:0, crewHotel:'Grand Hotel Napoca', crewIn:'', crewOut:'',
  drvCount:0, drvHotel:'Golden Tulip Ana Dome',
  extraCovered:false,
  travelMode:'flying',
  flyFrom:'', flyAirport:'CLJ', flyArrival:'', flyDepart:'',
  nlReg:'', nlParking:'', sdReg:'', sdCar:'', mixedNotes:'',
  riderRcvd:false, riderApproved:false, dietaryReqs:'',
  // ── Sent flags with hard deadlines ────────────────────────────────
  // must be covered by Step 3:
  brochureSent:false, timelineSent:false, merchSent:false,
  hotelDescSent:false, distancesSent:false, sponsorExpSent:false,
  // must be covered by Step 5:
  hotelConfirmed:false, angelExplained:false, riderAltShared:false,
  drAllocated:false, transferOverviewSent:false, cateringDescSent:false,
  // must be covered by Step 7:
  routeFormSent:false, itinSent:false, menuSent:false,
  drConfirmed:false, guestListExplained:false, angelAllocated:false,
  // Step 5–7 context
  guestListReq:false, pressScheduled:false, mealTimesConf:false,
  angelName:'', angelPhone:'', bsmName:'', drDetails:'',
};

// Hard deadline: must be covered no later than this step
const DEADLINE = {
  brochureSent:3, timelineSent:3, merchSent:3,
  hotelDescSent:3, distancesSent:3, sponsorExpSent:3,
  hotelConfirmed:5, angelExplained:5, riderAltShared:5,
  drAllocated:5, transferOverviewSent:5, cateringDescSent:5,
  routeFormSent:7, itinSent:7, menuSent:7,
  drConfirmed:7, guestListExplained:7, angelAllocated:7,
};

// include(flag): should this block appear in the current step's email?
// YES if: flag not sent AND deadline <= current step
function include(flag) { return !S[flag] && DEADLINE[flag] <= S.step; }
// overdue(flag): was it due in an EARLIER step?
function overdue(flag) { return !S[flag] && DEADLINE[flag] < S.step; }
// hasCatchup: are there ANY overdue blocks at this step?
function hasCatchup(step) { return Object.keys(DEADLINE).some(f => !S[f] && DEADLINE[f] < step); }

// ══════════════════════════════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════════════════════════════
const CLOSED = {};
function toggleSec(id) {
  CLOSED[id] = !CLOSED[id];
  document.getElementById('sec-'+id).classList.toggle('closed', !!CLOSED[id]);
  document.getElementById('arr-'+id).textContent = CLOSED[id] ? '▶' : '▼';
}
function setTravel(mode) {
  S.travelMode = mode;
  document.querySelectorAll('.travel-btn').forEach(el => el.classList.toggle('on', el.dataset.mode === mode));
  ['flying','nightliner','selfdriving','mixed'].forEach(m => {
    const el = document.getElementById('fld-'+m);
    if (el) el.style.display = m === mode ? '' : 'none';
  });
  upd();
}
function fmtDate(d) {
  if (!d) return '[DATE TBC]';
  return new Date(d+'T12:00:00').toLocaleDateString('en-GB', {day:'numeric',month:'long',year:'numeric'});
}
const A    = () => S.artistName || '[Artist Name]';
const TM   = () => S.tmName    || '[TM Name]';
const LEAD = () => S.advLead   || '[Your Name]';
const has  = t  => ({a:S.aCount>0, b:S.bCount>0, crew:S.crewCount>0, drv:S.drvCount>0}[t]);
const rooms = n => n===1 ? '1 room' : `${n} rooms`;

const HOTELS = { a:()=>S.aHotel, b:()=>S.bHotel, crew:()=>S.crewHotel, drv:()=>S.drvHotel };
const STARS  = { a:'★★★★★', b:'★★★★', crew:'★★★★', drv:'★★★' };
const LABELS = { a:'A-Party', b:'B-Party', crew:'Crew', drv:'Drivers / Truck Crew' };
const INS    = () => ({a:S.aIn, b:S.bIn, crew:S.crewIn, drv:''});
const OUTS   = () => ({a:S.aOut, b:S.bOut, crew:S.crewOut, drv:''});
const COUNTS = () => ({a:S.aCount, b:S.bCount, crew:S.crewCount, drv:S.drvCount});

function activeTiers() { return ['a','b','crew','drv'].filter(t => has(t)); }
function hotelBlock(tier, dates=true) {
  const n=COUNTS()[tier], h=HOTELS[tier](), ci=INS()[tier], co=OUTS()[tier];
  let s = `${LABELS[tier].toUpperCase()} — ${h} ${STARS[tier]}\n${rooms(n)} per contracted allocation`;
  if (dates && ci && co) s += `\nCheck-in: ${fmtDate(ci)}  |  Check-out: ${fmtDate(co)}`;
  return s;
}

// ══════════════════════════════════════════════════════════════════════
// CONTENT BLOCKS — each block is a pure function returning a string
// ══════════════════════════════════════════════════════════════════════
function bBrochure()   { return `I've attached the Electric Castle festival brochure — a great overview of the site, the atmosphere, and what to expect on the ground.`; }
function bTimeline()   { return `The advancing timeline is attached — this shows what we need from you and by when.`; }
function bMerch()      { return `The merchandise policy is also attached — this covers the on-site process and revenue arrangements for selling merch at Electric Castle.`; }

function bHotelDescs() {
  const L = [`HOTEL OPTIONS\n`];
  if (has('a'))    L.push(`   A-Party  →  ${HOTELS.a()} ${STARS.a}`);
  if (has('b'))    L.push(`   B-Party  →  ${HOTELS.b()} ${STARS.b}`);
  if (has('crew')) L.push(`   Crew     →  ${HOTELS.crew()} ${STARS.crew}`);
  if (has('drv'))  L.push(`   Drivers  →  ${HOTELS.drv()} ${STARS.drv}`);
  L.push(`\nAll properties are in central Cluj-Napoca. I'm happy to share more detail on any — just ask.`);
  return L.join('\n');
}

function bDistances() {
  if (S.travelMode === 'flying')
    return `DISTANCES & JOURNEY TIMES\n   • ${S.flyAirport||'CLJ'} Airport → City Hotels:            approx. 8km / 15 min\n   • City Hotels → Festival site (Bonțida):  approx. 30km / 35–40 min`;
  return `DISTANCES & JOURNEY TIMES\n   • City Hotels → Festival site (Bonțida):  approx. 30km / 35–40 min`;
}

function bSponsor() {
  return `FESTIVAL SPONSORSHIP OBLIGATIONS\nElectric Castle has the following exclusivity arrangements that affect rider items:\n   • Beer:  Birra Moretti — no other beer brands can be supplied on site\n   • Water: Perla Harghitei — no other still water brands can be supplied on site\nWe'll flag any other items we're unable to fulfil exactly and offer alternatives for your approval.`;
}

function bHotelConfirm() {
  const L = [`HOTEL CONFIRMATIONS\n`];
  activeTiers().forEach(t => { L.push(hotelBlock(t,true)); L.push(''); });
  L.push(`I'll introduce you to Sabina, who handles all hotel operations, for any room changes, billing queries, or special arrangements.`);
  if (!S.extraCovered) L.push(`Any rooms beyond the contracted allocation are billed at the hotel's standard rate, settled directly with the property.`);
  else                 L.push(`Additional nights are covered by the festival — flag any requirements to Sabina directly.`);
  return L.join('\n');
}

function bAngelExplained() {
  return `YOUR ARTIST LIAISON — ANGEL\nEvery artist at Electric Castle is assigned a dedicated on-site liaison we call an Angel. Your Angel will meet you at the festival arrival point and stay with you throughout your entire visit — they're your immediate point of contact for anything on the ground: getting to your dressing room, coordinating with catering, navigating the site, or anything else that comes up.\n\nWe'll confirm your Angel's name and contact details as soon as the allocation is finalised.`;
}

function bAngelAllocated() {
  const angel = S.angelName || '[Angel Name TBC]';
  const phone = S.angelPhone || '[Phone TBC]';
  return `YOUR ANGEL — CONFIRMED\n   Name:  ${angel}\n   Phone: ${phone}\n\n${S.angelName ? `${S.angelName} will meet you at the festival arrival point and will be with you for the duration of your visit. For anything on the day — they are your first call.` : `Your Angel will be in touch directly ahead of the festival.`}`;
}

function bRider() {
  if (S.riderRcvd) {
    return `RIDER\nThank you — the rider has been received and we're working through it. The alternatives sheet is live here: [LINK]. Please review and approve the alternatives shown.\n\nFestival obligations (non-negotiable):\n   • Beer:  Birra Moretti\n   • Water: Perla Harghitei`;
  }
  return `RIDER\n⚠ We haven't yet received your hospitality rider. Please send the most current version as soon as possible, including all dietary requirements for the full travel party.\n\nPlease note our festival-wide exclusivity obligations:\n   • Beer:  Birra Moretti\n   • Water: Perla Harghitei\nWe'll flag any other items we can't fulfil exactly and share alternatives.`;
}

function bDrAllocated() {
  if (S.drDetails) return `DRESSING ROOM\n${S.drDetails}\n\nYour Angel will take you there directly on arrival.`;
  return `DRESSING ROOM\nAllocation is being finalised — full details to follow. If you have any specific setup requirements (furniture, AV, etc.), please send them now.`;
}

function bTransferOverview() {
  const mode = S.travelMode;
  if (mode === 'flying')
    return `GROUND TRANSFERS\nWe'll arrange all transfers between the airport, hotels, and festival site. I'll follow up shortly with the route request form — please have an idea of passenger numbers per leg and whether you'd prefer a shared shuttle or dedicated vehicle.`;
  if (mode === 'nightliner')
    return `GROUND TRANSFERS — NIGHTLINER\nWe'll arrange secure parking in the artist compound at the festival site. Please confirm vehicle registration number(s) and approximate arrival time so we can prepare your site entry pass.`;
  if (mode === 'selfdriving')
    return `GROUND TRANSFERS — DRIVING\nArtist parking is adjacent to the backstage entrance. We'll prepare vehicle passes — please confirm registration number(s) and vehicle make/model.`;
  return `GROUND TRANSFERS\nWe'll coordinate transfers separately for flying guests (airport ↔ hotel ↔ site) and driving/nightliner arrivals (parking in the artist compound). Details follow once travel plans are confirmed.`;
}

function bCatering() {
  return `CATERING\nHot meals are served three times daily in the artist catering area on site. The à la carte menu will follow — please confirm meal time preferences and all dietary requirements for the travel party so we can brief the catering team in advance.`;
}

function bRouteForm() {
  const mode = S.travelMode;
  if (mode === 'flying')
    return `TRANSFERS — ROUTE REQUEST FORM\nRoute request form: [LINK] — please complete with passenger numbers per leg, luggage needs, and preferred timings.\n\nReference timings:\n   • ${S.flyAirport||'CLJ'} Airport → Hotels:       approx. 15 min\n   • Hotels → Festival site (Bonțida):   approx. 35–40 min\n   • Festival site → ${S.flyAirport||'CLJ'} Airport: approx. 40 min`;
  if (mode === 'nightliner')
    return `NIGHTLINER PARKING\nParking in the artist compound is confirmed. The transport team will follow up with exact access instructions and shower facility timings.${S.nlReg ? `\n\nVehicle noted: ${S.nlReg}` : ''}`;
  if (mode === 'selfdriving')
    return `ARTIST PARKING\nParking passes are being prepared for the backstage entrance.${S.sdReg ? `\nVehicle: ${S.sdReg}${S.sdCar ? ` — ${S.sdCar}` : ''}` : '\nPlease confirm registration number(s) so we can prepare the pass.'}`;
  return `TRANSFERS — ROUTE REQUEST FORM\nRoute request form: [LINK]\nPlease complete it for all sub-groups — flying guests and driving arrivals each have their own section.`;
}

function bItinerary() {
  return `ITINERARY V1\nFirst draft itinerary: [LINK]\n\nThis is a live working document — please review and flag anything that needs adjusting. Press and interview slots are currently blank; let me know if you'd like to schedule any media.\n${S.perfDate ? `\nPerformance: ${fmtDate(S.perfDate)}${S.stageName ? ` — ${S.stageName}` : ''}` : ''}`;
}

function bMenu() {
  return `CATERING — À LA CARTE MENU\nMenu attached. Please:\n   • Confirm preferred meal times (breakfast / lunch / dinner)\n   • Send advance pre-orders${S.dietaryReqs ? `\n\nDietary requirements on file: ${S.dietaryReqs}\nPlease confirm these are still accurate for all travel party members.` : '\n   • Confirm all dietary requirements for the full travel party'}`;
}

function bGuestList() {
  return `GUEST LIST\nGuest list is available. Please send all names (first + last name, plus ID type) directly to me.\n⚠ Deadline: [DATE TBC] — requests cannot be accepted after this point.`;
}

// ══════════════════════════════════════════════════════════════════════
// EMAIL GENERATORS
// ══════════════════════════════════════════════════════════════════════
const SEP = '─'.repeat(40);

function section(title, content) { return `${SEP}\n${title}\n${SEP}\n\n${content}\n`; }

function genStep1() {
  const att = ['Festival Brochure', 'Advancing Timeline', 'Merch Policy'];
  const L = [
    `Dear ${TM()},\n`,
    `My name is ${LEAD()} and I'll be your dedicated hospitality contact for ${A()}'s performance at Electric Castle 2025.\n`,
    `Electric Castle takes place at the Banffy Castle estate in Bonțida — a medieval setting around 30km outside Cluj-Napoca, Transylvania. We're really looking forward to welcoming you.\n`,
    bBrochure(), bTimeline(), bMerch(), '',
  ];
  if (activeTiers().length) { L.push(section('HOTELS', bHotelDescs())); }
  L.push(section('DISTANCES', bDistances()));
  L.push(section('SPONSORSHIP OBLIGATIONS', bSponsor()));
  L.push(`${SEP}\nWHAT WE NEED FROM YOU\n${SEP}\n`);
  L.push(`Could you please confirm the following at your earliest convenience:\n`);
  L.push(`1. TRAVEL PARTY SIZE`);
  if (has('a'))    L.push(`   A-Party:  ${rooms(S.aCount)} contracted`);
  if (has('b'))    L.push(`   B-Party:  ${rooms(S.bCount)} contracted`);
  if (has('crew')) L.push(`   Crew:     ${rooms(S.crewCount)} contracted`);
  if (has('drv'))  L.push(`   Drivers:  ${rooms(S.drvCount)} contracted`);
  L.push(`   Please confirm whether these numbers are accurate and send a rooming list when ready.\n`);
  L.push(`2. HOTEL REQUIREMENTS\n   Room types (double/twin/single), check-in/out dates, and any special requirements per group.\n`);
  L.push(`3. TRAVEL DETAILS`);
  if (S.travelMode==='flying') { L.push(`   Flight details when available — routing into ${S.flyAirport||'CLJ'} is recommended.`); if (S.flyFrom) L.push(`   Understood you'll be flying from ${S.flyFrom}.`); }
  else if (S.travelMode==='nightliner') L.push(`   Vehicle registration number(s) and approximate site arrival time.`);
  else if (S.travelMode==='selfdriving') L.push(`   Vehicle registration number(s) — needed for parking passes.`);
  else L.push(`   Please confirm who is flying vs. arriving by nightliner/vehicle so we can plan each group's transfers.`);
  L.push('\n4. HOSPITALITY RIDER\n   Please send the most current version of your rider, including all dietary requirements for the full travel party.\n');
  L.push(`${SEP}\n\nAny questions — I'm here.\n\nWarm regards,\n${LEAD()}\nElectric Castle Hospitality Team`);
  if (S.ccEmail) L.push(`\nCC: ${S.ccEmail}`);
  return { body: L.join('\n'), att };
}

function genStep3() {
  const att = [];
  const L = [
    `Dear ${TM()},\n`,
    `Thank you for the information — I'm pleased to confirm the following for ${A()}'s visit to Electric Castle 2025.\n`,
    section('HOTELS', bHotelConfirm()),
    section('YOUR ANGEL', bAngelExplained()),
    section('RIDER', bRider()),
    section('DRESSING ROOM', bDrAllocated()),
    section('GROUND TRANSFERS', bTransferOverview()),
    section('CATERING', bCatering()),
  ];
  // Catch-up from Step 1
  const catchups = [];
  if (!S.brochureSent)  { catchups.push('festival brochure'); att.push('Festival Brochure'); }
  if (!S.timelineSent)  { catchups.push('advancing timeline'); att.push('Advancing Timeline'); }
  if (!S.merchSent)     { catchups.push('merchandise policy'); att.push('Merch Policy'); }
  if (!S.distancesSent) { catchups.push('distances overview'); }
  if (catchups.length)  { L.push(`Also attaching/including for reference: ${catchups.join(', ')}.\n`); }
  L.push(`${SEP}\n\nI'll follow up shortly with the route request form, dressing room confirmation, and itinerary draft.\n\nWarm regards,\n${LEAD()}\nElectric Castle Hospitality Team`);
  if (S.ccEmail) L.push(`\nCC: ${S.ccEmail}`);
  return { body: L.join('\n'), att };
}

function genStep5() {
  const att = [];
  const catchup = hasCatchup(5);
  const L = [`Dear ${TM()},\n`];

  if (catchup) {
    L.push(`I want to make sure everything is in order ahead of ${A()}'s visit to Electric Castle 2025. A number of threads have been running in parallel — this email brings everything together and covers any outstanding items.\n`);
  } else {
    L.push(`We're getting close — here is everything you need to know for ${A()}'s visit to Electric Castle 2025.\n`);
  }

  // ── General info (overdue from Step 1) ────
  const generalBlocks = [];
  if (include('brochureSent'))   { generalBlocks.push(bBrochure()); att.push('Festival Brochure'); }
  if (include('distancesSent'))  generalBlocks.push(bDistances());
  if (include('sponsorExpSent')) generalBlocks.push(bSponsor());
  if (generalBlocks.length)      { L.push(section('GENERAL INFORMATION', generalBlocks.join('\n\n'))); }

  // ── Hotels ────
  const hotelContent = [];
  if (include('hotelDescSent'))    hotelContent.push(bHotelDescs());
  if (include('hotelConfirmed'))   hotelContent.push(bHotelConfirm());
  else if (S.hotelConfirmed) {
    // Already confirmed — quick recap
    const recap = activeTiers().map(t => hotelBlock(t,true)).join('\n\n') + '\n\nFor room changes or billing, contact Sabina directly.';
    hotelContent.push(recap);
  }
  if (hotelContent.length) L.push(section('HOTEL DETAILS', hotelContent.join('\n\n')));

  // ── Angel ────
  const angelBlocks = [];
  if (include('angelExplained'))  angelBlocks.push(bAngelExplained());
  if (include('angelAllocated')) {
    if (S.angelName) angelBlocks.push(bAngelAllocated());
    else angelBlocks.push(`Your Angel allocation is being finalised — I'll send name and contact as soon as confirmed.`);
  }
  if (angelBlocks.length) L.push(section('YOUR ANGEL', angelBlocks.join('\n\n')));

  // ── Rider ────
  if (include('riderAltShared')) L.push(section('RIDER', bRider()));

  // ── Dressing room ────
  if (include('drAllocated') || include('drConfirmed')) L.push(section('DRESSING ROOM', bDrAllocated()));

  // ── Transfers ────
  const xferBlocks = [];
  if (include('transferOverviewSent')) xferBlocks.push(bTransferOverview());
  if (include('routeFormSent'))        xferBlocks.push(bRouteForm());
  if (xferBlocks.length) L.push(section('GROUND TRANSFERS', xferBlocks.join('\n\n')));

  // ── Itinerary ────
  if (include('itinSent')) L.push(section('ITINERARY V1', bItinerary()));

  // ── Catering ────
  const caterBlocks = [];
  if (include('cateringDescSent')) caterBlocks.push(bCatering());
  if (include('menuSent'))         { caterBlocks.push(bMenu()); att.push('À la carte menu'); }
  if (caterBlocks.length) L.push(section('CATERING', caterBlocks.join('\n\n')));

  // ── Guest list (if requested) ────
  if (S.guestListReq && include('guestListExplained')) L.push(section('GUEST LIST', bGuestList()));

  // ── Catch-up merch ────
  if (include('merchSent')) { L.push(`Merchandise policy attached.`); att.push('Merch Policy'); }
