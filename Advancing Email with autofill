      <label class="chk-row"><input type="checkbox" id="guestListReq"   onchange="upd()"><span>Guest list requested by artist</span></label>
      <label class="chk-row"><input type="checkbox" id="pressScheduled" onchange="upd()"><span>Press / media scheduled</span></label>
      <label class="chk-row"><input type="checkbox" id="mealTimesConf"  onchange="upd()"><span>Meal times confirmed by TM</span></label>
      <div><label class="field-label">Angel Name</label><input type="text" id="angelName" placeholder="Angel's full name" oninput="upd()"></div>
      <div><label class="field-label">Angel Phone</label><input type="text" id="angelPhone" placeholder="+40 7xx xxx xxx" oninput="upd()"></div>
      <div><label class="field-label">Backstage Manager Name</label><input type="text" id="bsmName" placeholder="BSM full name" oninput="upd()"></div>
      <div><label class="field-label">Dressing Room Details</label><textarea id="drDetails" placeholder="e.g. DR3, ground floor, Stage Left" oninput="upd()"></textarea></div>
