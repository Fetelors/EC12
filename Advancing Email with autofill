      <label class="chk-row"><input type="checkbox" id="routeFormSent"      onchange="upd()"><span>Route request form link sent</span></label>
      <label class="chk-row"><input type="checkbox" id="itinSent"           onchange="upd()"><span>Itinerary V1 shared</span></label>
      <label class="chk-row"><input type="checkbox" id="menuSent"           onchange="upd()"><span>À la carte menu shared</span></label>
      <label class="chk-row"><input type="checkbox" id="drConfirmed"        onchange="upd()"><span>Dressing room details confirmed</span></label>
      <label class="chk-row"><input type="checkbox" id="guestListExplained" onchange="upd()"><span>Guest list process & deadline explained</span></label>
      <label class="chk-row"><input type="checkbox" id="angelAllocated"     onchange="upd()"><span>Angel allocated — name + contact shared</span></label>

