const BLOCK_LABELS = {
  brochureSent:'Brochure', timelineSent:'Timeline', merchSent:'Merch policy',
  hotelDescSent:'Hotel descriptions', distancesSent:'Distances', sponsorExpSent:'Sponsor exclusions',
  hotelConfirmed:'Hotel confirmation', angelExplained:'Angel intro (what it is)', riderAltShared:'Rider alternatives',
