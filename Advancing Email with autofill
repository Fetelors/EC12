function tmItems(step) {
  if (step === 2) return [
    {i:'👥', t:'Confirm travel party size', d:`Confirm vs contracted — A-Party${S.bCount>0?', B-Party':''}${S.crewCount>0?', Crew':''}${S.drvCount>0?', Drivers':''}`},
    {i:'🏨', t:'Hotel requirements', d:'Room types, check-in/out dates, special requirements per group'},
    {i:'✈️', t:'Travel details', d:S.travelMode==='flying'?`Flights routing into ${S.flyAirport||'CLJ'}`:S.travelMode==='nightliner'?'Vehicle reg + approx. arrival time':S.travelMode==='selfdriving'?'Reg number(s) + make/model':'Who is flying vs driving/nightliner'},
    {i:'📋', t:'Hospitality rider', d:'Final version + all dietary requirements for full travel party'},
  ];
  if (step === 4) return [
    {i:'✈️', t:'Confirmed flight details',        d:'Flight numbers, arrival + departure times'},
    {i:'📋', t:'Rooming list',                    d:'One name per room, matching contracted numbers'},
    {i:'🥗', t:'Dietary requirements confirmed',  d:'All travel party members; meal times if possible'},
    {i:'🔀', t:'Transfer preferences',            d:'Passenger numbers per leg, shuttle vs. dedicated vehicle'},
    {i:'✅', t:'Rider alternatives approval',     d:'Review and approve the alternatives sheet — required before fulfilment'},
  ];
  if (step === 6) {
    const items = [];
    if (S.guestListReq) items.push({i:'🎟️', t:'Guest list (final)', d:'First + last name, ID type per guest — deadline [DATE TBC]'});
    items.push({i:'🍽️', t:'Confirm meal times', d:'Breakfast, lunch, and dinner — on site and at hotel'});
    items.push({i:'📦', t:'Pre-orders from à la carte menu', d:'Advance orders ensure availability — send asap'});
    if (!S.riderApproved) items.push({i:'✅', t:'Rider alternatives — URGENT', d:'Not yet approved — cannot guarantee fulfilment without sign-off'});
    if (S.pressScheduled) items.push({i:'📸', t:'Media / press schedule', d:'Full details for interviews or photo calls'});
    return items;
  }
  return [];
}

