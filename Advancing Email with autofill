      <label class="chk-row"><input type="checkbox" id="transferOverviewSent" onchange="upd()"><span>Ground transfer overview sent</span></label>
      <label class="chk-row"><input type="checkbox" id="cateringDescSent"     onchange="upd()"><span>Catering amenities described</span></label>

      <div class="sent-step-hd" style="margin-top:6px">
        <span class="sent-step-label ec">EC — Step 5</span>
        <div class="sent-step-line"></div>
        <span class="sent-step-due">hard deadline: Step 7</span>
