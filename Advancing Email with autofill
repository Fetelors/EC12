function subject(step) {
  const a = A();
  const map = {
    1:`${a}  //  Electric Castle 2025  //  Hospitality Advancing — Welcome`,
    2:`${a}  //  Electric Castle 2025  //  Info Needed — Step 2`,
    3:`${a}  //  Electric Castle 2025  //  Hotel Confirmations & On The Ground`,
    4:`${a}  //  Electric Castle 2025  //  Travel Details Needed — Step 4`,
    5: hasCatchup(5)
      ? `${a}  //  Electric Castle 2025  //  Hospitality — Full Update & Outstanding Actions`
      : `${a}  //  Electric Castle 2025  //  Itinerary V1, Transfers & Menus`,
    6:`${a}  //  Electric Castle 2025  //  Guest List & Pre-Orders`,
    7:`${a}  //  Electric Castle 2025  //  All Set — Final Details & Your Team`,
  };
  return map[step] || `${a}  //  EC 2025  //  Step ${step}`;
}

