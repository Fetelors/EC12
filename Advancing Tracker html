function svgEl(tag, attrs={}) {
  const el = document.createElementNS('http://www.w3.org/2000/svg', tag);
  for (const [k,v] of Object.entries(attrs)) el.setAttribute(k,v);
  return el;
}
function measureTextWidth(text, fontSize) {
  const svg = document.getElementById('diagram');
  const t = svgEl('text', {'font-family':"'DM Sans',sans-serif",'font-size':fontSize,'font-weight':500,visibility:'hidden'});
  t.textContent = text; svg.appendChild(t);
  const w = t.getBBox().width; svg.removeChild(t);
  return Math.ceil(w);
}
function trunc(str, n=28) { return str.length > n ? str.slice(0,n-1)+'…' : str; }

