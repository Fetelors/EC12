    const lines   = board.label.split('\n');
    const r       = Math.round(FS * 3.5);   // circle radius
    const isExp   = expandedBoard === board.id;
    const node    = svgEl('g', {class:'node-wrap','data-id':board.id,transform:`translate(${pos.x},${pos.y})`});

    // Outer halo
    node.appendChild(svgEl('circle',{r:r+10, fill: isExp ? cluster.color : cluster.light, opacity: isExp ? 0.2 : 0.4}));
    // Main circle
    node.appendChild(svgEl('circle',{
      r,
      fill:   isExp ? cluster.mid  : 'white',
      stroke: cluster.color,
      'stroke-width': isExp ? 0 : 2.5,
      'stroke-dasharray': (board.isNew && !isExp) ? '8,4' : 'none',
      filter: 'url(#sh-sm)', class:'node-card',
    }));

    // Labels
    const ls = Math.round(FS * 1.0);
    const textColor = isExp ? 'white' : cluster.color;
    lines.forEach((line, li) => {
      const yOff = lines.length > 1 ? (li===0 ? -Math.round(ls*0.55) : Math.round(ls*0.55)) : 0;
      const t = svgEl('text',{y:yOff, fill:textColor, class:'node-label-main','font-size':Math.round(FS*0.7)});
      t.textContent = line; node.appendChild(t);
    });
    const countY = lines.length > 1 ? Math.round(ls*1.6) : Math.round(FS*0.78);
    const fc = svgEl('text',{y:countY, fill:isExp?'rgba(255,255,255,0.7)':cluster.color, class:'node-count','font-size':Math.round(FS*0.5), opacity:0.85});
    fc.textContent = `${board.fields} fields`; node.appendChild(fc);

    // NEW badge — small filled circle top-right
    if (board.isNew) {
      const bR = Math.round(FS*0.5), bX = Math.round(r*0.7), bY = -Math.round(r*0.7);
      node.appendChild(svgEl('circle',{cx:bX,cy:bY,r:bR,fill:cluster.color}));
      const nt = svgEl('text',{x:bX,y:bY+1,fill:'white','font-size':Math.round(FS*0.36),'font-weight':800,'text-anchor':'middle','dominant-baseline':'middle'});
      nt.textContent='N'; node.appendChild(nt);
    }

    node.addEventListener('click', ()=>toggleBoard(board.id));
    node.addEventListener('mouseenter', e=>showTip(e,board.label.replace('\n',' '),`${cluster.label} · ${board.isNew?'New EC12':'Existing'} · ${board.fields} fields`,'Click to expand'));
    node.addEventListener('mouseleave', hideTip);
    g.appendChild(node);
  });
}

// ═══════════════════════════════════════════════════════════════
// RENDER FIELD LAYER
// ═══════════════════════════════════════════════════════════════
function renderFieldLayer() {
  document.getElementById('field-pills').innerHTML='';
  document.getElementById('field-connectors').innerHTML='';
  if (!expandedBoard || fieldMode==='none') return;
  fieldMode==='connected' ? renderConnected() : renderFieldList();
}

function renderConnected() {
  const fpg=document.getElementById('field-pills'), fcg=document.getElementById('field-connectors');
  const board=BOARDS.find(b=>b.id===expandedBoard); if(!board) return;
  const cluster=CLUSTERS[board.cluster];
  const conns=FIELD_CONNECTIONS.filter(c=>c.boardId===expandedBoard);
  if(!conns.length) return;

  const bp=boardPillPositions(expandedBoard,conns.length);
  const ap=aatPillPositions(expandedBoard,conns.length);
  const hdrFS=Math.round(FS*0.75);

  // Headers
  const labelY=Math.min(...ap.map(p=>p.y),...bp.map(p=>p.y))-pillH()/2-Math.round(FS*1.0);
  const aHdr=svgEl('text',{x:ap[0].x,y:labelY,fill:'#52B788','font-family':"'DM Sans',sans-serif",'font-size':hdrFS,'font-weight':700,'text-anchor':'middle','letter-spacing':'0.5'});
  aHdr.textContent='ARTIST ADVANCING TRACKER'; fcg.appendChild(aHdr);
  const bHdr=svgEl('text',{x:bp[0].x,y:labelY,fill:cluster.color,'font-family':"'DM Sans',sans-serif",'font-size':hdrFS,'font-weight':700,'text-anchor':'middle','letter-spacing':'0.5'});
  bHdr.textContent=board.label.replace('\n',' ').toUpperCase(); fcg.appendChild(bHdr);

  // Spine lines
  const maxY=Math.max(...ap.map(p=>p.y),...bp.map(p=>p.y))+pillH()/2+6;
  fcg.appendChild(svgEl('line',{x1:ap[0].x,y1:labelY+6,x2:ap[0].x,y2:maxY,stroke:'#1B4332','stroke-width':0.8,opacity:0.12}));
  fcg.appendChild(svgEl('line',{x1:bp[0].x,y1:labelY+6,x2:bp[0].x,y2:maxY,stroke:cluster.color,'stroke-width':0.8,opacity:0.12}));

  // Elbow from board node
  const p=POS[expandedBoard], rad=toRad(p.angle-90), rx=Math.cos(rad), ry=Math.sin(rad);
  const eX=CENTRE.x+rx*(p.r+Math.round(FS*2)), eY=CENTRE.y+ry*(p.r+Math.round(FS*2));
  const aX=CENTRE.x+rx*(p.r+bpDist()), aY=CENTRE.y+ry*(p.r+bpDist());
  fcg.appendChild(svgEl('line',{x1:eX,y1:eY,x2:aX,y2:aY,stroke:cluster.color,'stroke-width':1.5,opacity:0.25}));
  fcg.appendChild(svgEl('circle',{cx:aX,cy:aY,r:3,fill:cluster.color,opacity:0.4}));

  conns.forEach((conn,i)=>{
    const bPos=bp[i], aPos=ap[i];
    const leftX=Math.min(aPos.x,bPos.x)+pillW()/2, rightX=Math.max(aPos.x,bPos.x)-pillW()/2;
    const line=svgEl('line',{x1:leftX,y1:aPos.y,x2:rightX,y2:aPos.y,stroke:conn.type==='key'?'#5B8FF9':'#B07FE8','stroke-width':1.5,'stroke-dasharray':conn.type==='mirror'?'6,4':'none',opacity:0.4,class:'field-connector'});
    line.addEventListener('mouseenter',e=>{line.setAttribute('opacity',1);line.setAttribute('stroke-width',3);showTip(e,`${conn.aatName} ↔ ${conn.boardName}`,conn.type==='key'?'↔ board relation':'⟵ mirror',`AAT: ${conn.aatFid}  ·  Board: ${conn.boardFid}`);});
    line.addEventListener('mouseleave',()=>{line.setAttribute('opacity',0.4);line.setAttribute('stroke-width',1.5);hideTip();});
    fcg.appendChild(line);
    fpg.appendChild(makeBox(bPos,conn.boardName,conn.type,cluster.color,false,e=>showTip(e,conn.boardName,board.label.replace('\n',' '),`${conn.type} · ${conn.boardFid}`)));
    fpg.appendChild(makeBox(aPos,conn.aatName,conn.type,'#1B4332',true,e=>showTip(e,conn.aatName,'Artist Advancing Tracker',`${conn.type} · ${conn.aatFid}`)));
  });
}

function renderFieldList() {
  const fpg=document.getElementById('field-pills'), fcg=document.getElementById('field-connectors');
  const board=BOARDS.find(b=>b.id===expandedBoard); if(!board) return;
  const cluster=CLUSTERS[board.cluster];
  const allFields=BOARD_FIELDS[expandedBoard]||[];
  const connMap={};
  FIELD_CONNECTIONS.filter(c=>c.boardId===expandedBoard).forEach(c=>{connMap[c.boardFid]=c;});
  const connectedFids=new Set(Object.keys(connMap));

  if (fieldMode==='input') {
    const fields=allFields.filter(f=>['input','status','date','people','file'].includes(f.type));
    const positions=singleColumnPositions(expandedBoard,fields.length); if(!positions.length) return;
    _drawColHdr(fcg,positions[0],cluster.color,board.label,expandedBoard);
    fields.forEach((f,i)=>fpg.appendChild(makeBox(positions[i],f.name,f.type,cluster.color,false,e=>showTip(e,f.name,`Type: ${f.type}`,f.fid))));
    return;
  }

  if (fieldMode==='all') {
    const cross=allFields.filter(f=>f.type==='key'||f.type==='mirror'||connectedFids.has(f.fid));
    const inp=allFields.filter(f=>!cross.includes(f));
    const totalRows=cross.length+(inp.length>0?inp.length+1:0);
    const positions=singleColumnPositions(expandedBoard,totalRows); if(!positions.length) return;
    _drawColHdr(fcg,positions[0],cluster.color,board.label,expandedBoard);

    const p=POS[expandedBoard], rad=toRad(p.angle-90), rx=Math.cos(rad), ry=Math.sin(rad);
    let xOff;
    if (Math.abs(rx)>0.2) xOff=rx>0?-(pillW()+pillGap()):(pillW()+pillGap());
    else xOff=ry<0?(pillW()+pillGap()):-(pillW()+pillGap());

    cross.forEach((f,i)=>{
      const bPos=positions[i];
      fpg.appendChild(makeBox(bPos,f.name,f.type,cluster.color,false,e=>showTip(e,f.name,`Type: ${f.type}`,f.fid)));
      const conn=connMap[f.fid];
      if (conn) {
        const aPos={x:bPos.x+xOff,y:bPos.y};
        const lX=Math.min(bPos.x,aPos.x)+pillW()/2, rX=Math.max(bPos.x,aPos.x)-pillW()/2;
        fcg.appendChild(svgEl('line',{x1:lX,y1:bPos.y,x2:rX,y2:bPos.y,stroke:f.type==='key'?'#5B8FF9':'#B07FE8','stroke-width':1.5,'stroke-dasharray':f.type==='mirror'?'6,4':'none',opacity:0.4}));
        fpg.appendChild(makeBox(aPos,conn.aatName,conn.type,'#1B4332',true,e=>showTip(e,conn.aatName,'Artist Advancing Tracker',`${conn.type} · ${conn.aatFid}`)));
      }
    });
    if (inp.length>0) {
      const dPos=positions[cross.length];
      const dl=svgEl('text',{x:dPos.x,y:dPos.y,'font-family':"'DM Sans',sans-serif",'font-size':Math.round(FS*0.65),'font-weight':700,'text-anchor':'middle','dominant-baseline':'middle',fill:cluster.color,opacity:0.45,'letter-spacing':'0.5'});
      dl.textContent='— INPUT FIELDS —'; fcg.appendChild(dl);
      inp.forEach((f,j)=>fpg.appendChild(makeBox(positions[cross.length+1+j],f.name,f.type,cluster.color,false,e=>showTip(e,f.name,`Type: ${f.type}`,f.fid),true)));
    }
    return;
  }
}

function _drawColHdr(fcg, topPos, color, boardLabel, boardId) {
  const labelY=topPos.y-pillH()/2-Math.round(FS*1.0);
  const hdr=svgEl('text',{x:topPos.x,y:labelY,fill:color,'font-family':"'DM Sans',sans-serif",'font-size':Math.round(FS*0.75),'font-weight':700,'text-anchor':'middle','letter-spacing':'0.5'});
  hdr.textContent=boardLabel.replace('\n',' ').toUpperCase(); fcg.appendChild(hdr);
  const p=POS[boardId]; if(!p) return;
  const rad=toRad(p.angle-90), rx=Math.cos(rad), ry=Math.sin(rad);
  fcg.appendChild(svgEl('line',{x1:CENTRE.x+rx*(p.r+Math.round(FS*2)),y1:CENTRE.y+ry*(p.r+Math.round(FS*2)),x2:CENTRE.x+rx*(p.r+bpDist()),y2:CENTRE.y+ry*(p.r+bpDist()),stroke:color,'stroke-width':1.5,opacity:0.25}));
}

function makeBox(pos, name, type, accentColor, isAat, onEnter, dimmed=false) {
  const ft=FT[type]||FT.input;
  const label=trunc(name);
  const tw=measureTextWidth(label,FS);
  const iconSp=Math.round(FS*1.55);
  const pw=tw+iconSp+Math.round(FS*0.9);
  const ph=pillH(), r=Math.round(ph/2);
  const iconX=-pw/2+Math.round(iconSp*0.45);
  const labelX=-pw/2+iconSp;
  const g=svgEl('g',{class:'field-box',transform:`translate(${pos.x},${pos.y})`,opacity:dimmed?0.45:1});

  if (isAat) {
    g.appendChild(svgEl('rect',{x:-pw/2,y:-ph/2,width:pw,height:ph,rx:r,fill:'#1B4332',filter:'url(#sh-sm)'}));
    g.appendChild(svgEl('rect',{x:-pw/2,y:-ph/2,width:5,height:ph,rx:r,fill:'#52B788'}));
    const ic=svgEl('text',{x:iconX,y:1,'font-size':Math.round(FS*0.68),'text-anchor':'middle','dominant-baseline':'middle','pointer-events':'none',fill:'#52B788','font-weight':700});
    ic.textContent=ft.icon; g.appendChild(ic);
    const lb=svgEl('text',{x:labelX,y:1,'font-family':"'DM Sans',sans-serif",'font-size':FS,'font-weight':500,'dominant-baseline':'middle','pointer-events':'none',fill:'rgba(255,255,255,0.92)'});
    lb.textContent=label; g.appendChild(lb);
  } else {
    g.appendChild(svgEl('rect',{x:-pw/2,y:-ph/2,width:pw,height:ph,rx:r,fill:'white',stroke:accentColor,'stroke-width':1.5,'stroke-opacity':0.35,filter:'url(#sh-sm)'}));
    g.appendChild(svgEl('circle',{cx:iconX,cy:0,r:Math.round(ph*0.22),fill:ft.bg}));
    const ic=svgEl('text',{x:iconX,y:1,'font-size':Math.round(FS*0.66),'text-anchor':'middle','dominant-baseline':'middle','pointer-events':'none',fill:ft.text,'font-weight':600});
    ic.textContent=ft.icon; g.appendChild(ic);
    const lb=svgEl('text',{x:labelX,y:1,'font-family':"'DM Sans',sans-serif",'font-size':FS,'font-weight':500,'dominant-baseline':'middle','pointer-events':'none',fill:ft.text});
    lb.textContent=label; g.appendChild(lb);
  }
  g.style.cursor='default';
  if (onEnter) { g.addEventListener('mouseenter',onEnter); g.addEventListener('mouseleave',hideTip); }
  return g;
}

