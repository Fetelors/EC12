  <button class="btn-mode" data-mode="input" onclick="setFieldMode('input')">✏ Input Fields</button>
  <button class="btn-mode" data-mode="all" onclick="setFieldMode('all')">⊞ All Fields</button>
  <div class="mode-sep"></div>
  <button class="btn-mode" data-mode="none" onclick="setFieldMode('none')">○ Overview only</button>
</div>

<div class="field-legend" id="field-legend">
  <span>Field types:</span>
  <div><span class="fl-chip" style="background:#E8F0FE;color:#3D6FD4">↔ Key</span> board relation</div>
  <div><span class="fl-chip" style="background:#F0E8FF;color:#8B5CC8">⟵ Mirror</span> pulled from source</div>
  <div><span class="fl-chip" style="background:#DCFAF0;color:#2A9574">✏ Input</span> direct entry</div>
  <div><span class="fl-chip" style="background:#FFF3DC;color:#C07A1A">ƒ Formula</span> calculated</div>
  <div><span class="fl-chip" style="background:#FFE8F5;color:#C0549A">◉ Status</span> dropdown / label</div>
</div>

<div class="instructions" id="instructions">
  Click any board to expand its connected fields — both AAT and the linked board unfurl simultaneously
</div>

<div class="sub-bar">
  <span class="ctrl-label">Filter:</span>
  <button class="btn-ctrl active" id="btn-all"      onclick="setFilter('all')">All boards</button>
  <button class="btn-ctrl"        id="btn-existing" onclick="setFilter('existing')">Existing only</button>
  <button class="btn-ctrl"        id="btn-new"      onclick="setFilter('new')">New boards</button>
  <div style="flex:1"></div>
  <button class="btn-ctrl" onclick="collapseAll()">✕ Collapse</button>
</div>

<div class="canvas-wrap" id="canvas-wrap">
  <div id="zoom-surface">
    <svg id="diagram" viewBox="-400 -400 2800 2800" xmlns="http://www.w3.org/2000/svg" style="overflow:visible">
      <defs>
        <filter id="sh-sm" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="3" stdDeviation="5" flood-color="rgba(0,0,0,0.09)"/>
        </filter>
        <filter id="sh-aat" x="-30%" y="-30%" width="160%" height="160%">
          <feDropShadow dx="0" dy="6" stdDeviation="14" flood-color="rgba(27,67,50,0.22)"/>
        </filter>
      </defs>
      <g id="base-connectors"></g>
      <g id="field-connectors"></g>
      <g id="field-pills"></g>
      <g id="nodes"></g>
    </svg>
  </div>
  <div class="zoom-controls">
    <button class="btn-zoom" onclick="zoomBy(0.8)"   title="Zoom out">−</button>
    <div class="zoom-level" id="zoom-label">100%</div>
    <button class="btn-zoom" onclick="zoomBy(1.25)"  title="Zoom in">+</button>
    <button class="btn-zoom reset" onclick="zoomReset()" title="Fit">FIT</button>
    <div class="zoom-sep"></div>
    <button class="btn-zoom font-btn" onclick="setFS(FS-2)" title="Smaller text">A−</button>
    <div class="zoom-level" id="font-label">24px</div>
    <button class="btn-zoom font-btn" onclick="setFS(FS+2)" title="Larger text">A+</button>
  </div>
</div>

<div id="aat-card">
  <div class="aat-card-header">
    <div><h2>Artist Advancing Tracker</h2><p>Central hub · 150 fields across all categories</p></div>
    <button class="aat-card-close" onclick="hideAATCard()">✕</button>
  </div>
  <div id="aat-card-nav" class="aat-card-nav" style="display:none"></div>
  <div class="aat-card-body" id="aat-card-body"></div>
</div>

<div id="tooltip"></div>

