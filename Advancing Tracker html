// ═══════════════════════════════════════════════════════════════
// ZOOM & PAN ENGINE
// ═══════════════════════════════════════════════════════════════
const surface=document.getElementById('zoom-surface');
const wrap=document.getElementById('canvas-wrap');
const zoomLbl=document.getElementById('zoom-label');
const Z={scale:1,tx:0,ty:0,minScale:0.1,maxScale:8};

function applyTransform(animate=false){
  surface.style.transition=animate?'transform 0.38s cubic-bezier(0.25,0.8,0.25,1)':'none';
  surface.style.transform=`translate(${Z.tx}px,${Z.ty}px) scale(${Z.scale})`;
  zoomLbl.textContent=Math.round(Z.scale*100)+'%';
}
function zoomToward(cx,cy,factor){
  const ns=Math.min(Z.maxScale,Math.max(Z.minScale,Z.scale*factor));
  const r=ns/Z.scale;
  Z.tx=cx-r*(cx-Z.tx); Z.ty=cy-r*(cy-Z.ty); Z.scale=ns;
  applyTransform();
}
function zoomBy(f){const r=wrap.getBoundingClientRect(); zoomToward(r.left+r.width/2,r.top+r.height/2,f);}
function zoomReset(){
  const r=wrap.getBoundingClientRect();
  Z.scale=Math.min(Z.maxScale,Math.max(Z.minScale,r.width/1600));
  Z.tx=(r.width-1600*Z.scale)/2; Z.ty=(r.height-1900*Z.scale)/2;
  applyTransform(true);
}
function zoomToSVGRect(svgX,svgY,svgW,svgH,pad=48){
  const svg=document.getElementById('diagram');
  const vb=svg.getAttribute('viewBox').split(' ').map(Number);
  const wr=wrap.getBoundingClientRect();
  const ppu=1600/vb[2];
  const ns=Math.min(Z.maxScale,Math.max(Z.minScale,Math.min((wr.width-pad*2)/(svgW*ppu),(wr.height-pad*2)/(svgH*ppu))));
  const cx=(svgX+svgW/2-vb[0])*ppu, cy=(svgY+svgH/2-vb[1])*ppu;
  Z.tx=wr.width/2-cx*ns; Z.ty=wr.height/2-cy*ns; Z.scale=ns;
  applyTransform(true);
}
let pinchDist=null,pinchMid=null;
wrap.addEventListener('touchstart',e=>{
  if(e.touches.length!==2)return;
  pinchDist=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
  pinchMid={x:(e.touches[0].clientX+e.touches[1].clientX)/2,y:(e.touches[0].clientY+e.touches[1].clientY)/2};
  e.preventDefault();
},{passive:false});
wrap.addEventListener('touchmove',e=>{
  if(e.touches.length!==2||!pinchDist)return;
  const d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
  const m={x:(e.touches[0].clientX+e.touches[1].clientX)/2,y:(e.touches[0].clientY+e.touches[1].clientY)/2};
  zoomToward(m.x,m.y,d/pinchDist);Z.tx+=m.x-pinchMid.x;Z.ty+=m.y-pinchMid.y;
  applyTransform();pinchDist=d;pinchMid=m;e.preventDefault();
},{passive:false});
wrap.addEventListener('touchend',()=>{pinchDist=null;pinchMid=null;});
wrap.addEventListener('wheel',e=>{e.preventDefault();zoomToward(e.clientX,e.clientY,e.ctrlKey?Math.pow(0.995,e.deltaY):(e.deltaY<0?1.1:0.91));},{passive:false});
let drag={active:false};
wrap.addEventListener('mousedown',e=>{if(e.target.closest('.node-wrap,.field-box,.field-connector'))return;drag={active:true,startX:e.clientX,startY:e.clientY,startTx:Z.tx,startTy:Z.ty};wrap.classList.add('panning');});
window.addEventListener('mousemove',e=>{if(!drag.active)return;Z.tx=drag.startTx+(e.clientX-drag.startX);Z.ty=drag.startTy+(e.clientY-drag.startY);applyTransform();});
window.addEventListener('mouseup',()=>{drag.active=false;wrap.classList.remove('panning');});
wrap.addEventListener('dblclick',e=>{const n=e.target.closest('.node-wrap');if(!n)return;const id=n.getAttribute('data-id');if(id&&id!=='aat'){e.stopPropagation();const svg=document.getElementById('diagram');const vb=svg.getAttribute('viewBox').split(' ').map(Number);const sr=svg.getBoundingClientRect();const pos=getNodePos(id);const vpx=sr.left+(pos.x-vb[0])*(sr.width/vb[2]),vpy=sr.top+(pos.y-vb[1])*(sr.height/vb[3]);const wr=wrap.getBoundingClientRect();const ns=Math.min(Z.maxScale,2.5);const r=ns/Z.scale;Z.tx=(vpx-wr.left)*(1-r)+Z.tx;Z.ty=(vpy-wr.top)*(1-r)+Z.ty;Z.scale=ns;applyTransform(true);}else if(id==='aat')zoomReset();});
window.addEventListener('load',()=>setTimeout(zoomReset,80));

renderBase();
</script>
