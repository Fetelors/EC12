// INTERACTIONS
// ═══════════════════════════════════════════════════════════════
function toggleBoard(id) {
  const was=expandedBoard===id;
  expandedBoard=was?null:id;
  renderNodes(); renderFieldLayer();
  if (!was && fieldMode!=='none') requestAnimationFrame(()=>requestAnimationFrame(()=>zoomToFitCluster(id)));
}
function collapseAll() { expandedBoard=null; renderNodes(); renderFieldLayer(); }
function setFieldMode(mode) {
  fieldMode=mode;
  document.querySelectorAll('.btn-mode').forEach(b=>b.classList.toggle('active',b.dataset.mode===mode));
  document.getElementById('field-legend').classList.toggle('visible',mode==='all'||mode==='input');
  const msgs={connected:'Click any board to expand connected fields',input:'Click any board to see its input fields',all:'Click any board — cross-board fields on top, input fields below',none:'Overview mode'};
  document.getElementById('instructions').textContent=msgs[mode]||'';
  renderNodes(); renderFieldLayer();
}
function setFilter(mode) {
  filterMode=mode;
  document.querySelectorAll('.btn-ctrl').forEach(b=>b.classList.remove('active'));
  document.getElementById(`btn-${mode}`).classList.add('active');
  BOARDS.forEach(board=>{
    const el=document.querySelector(`.node-wrap[data-id="${board.id}"]`); if(!el) return;
    if(mode==='all') el.setAttribute('opacity',1);
    else if(mode==='existing') el.setAttribute('opacity',board.isNew?0.12:1);
    else if(mode==='new') el.setAttribute('opacity',board.isNew?1:0.12);
  });
}

function zoomToFitCluster(boardId) {
  const conns=FIELD_CONNECTIONS.filter(c=>c.boardId===boardId);
  let fields=BOARD_FIELDS[boardId]||[];
  if(fieldMode==='input') fields=fields.filter(f=>['input','status','date','people','file'].includes(f.type));
  let rowCount=fieldMode==='connected'?conns.length:fields.length;
  if(fieldMode==='all') rowCount=fields.length+(conns.length>0?conns.length+1:0);
  if(rowCount===0) return;
  const bp=boardPillPositions(boardId,rowCount);
  const ap=aatPillPositions(boardId,rowCount);
  const all=[...bp,...ap];
  const halfPW=pillW()/2;
  const x1=Math.min(...all.map(p=>p.x))-halfPW-20;
  const x2=Math.max(...all.map(p=>p.x))+halfPW+20;
  const y1=Math.min(...all.map(p=>p.y))-pillH()/2-Math.round(FS*2.5);
  const y2=Math.max(...all.map(p=>p.y))+pillH()/2+20;
  const np=getNodePos(boardId), nr=Math.round(FS*2.5);
  zoomToSVGRect(Math.min(x1,np.x-nr),Math.min(y1,np.y-nr),Math.max(x2,np.x+nr)-Math.min(x1,np.x-nr),Math.max(y2,np.y+nr)-Math.min(y1,np.y-nr),56);
}

