// GEOMETRY — EXACT VERTICAL APPROACH FROM WORKING REFERENCE
// ═══════════════════════════════════════════════════════════════
function toRad(d) { return d * Math.PI / 180; }
function polarToXY(angle, r) {
  const rad = toRad(angle-90);
  return { x: CENTRE.x + r*Math.cos(rad), y: CENTRE.y + r*Math.sin(rad) };
}
function getNodePos(id) {
  if (id==='aat') return CENTRE;
  const p = POS[id]; if (!p) return CENTRE;
  return polarToXY(p.angle, p.r);
}

// Board pills: vertical column anchored radially outside node
function boardPillPositions(boardId, count) {
  const p = POS[boardId];
  const rad = toRad(p.angle-90);
  const rx = Math.cos(rad), ry = Math.sin(rad);
  const ax = CENTRE.x + rx*(p.r + bpDist());
  const ay = CENTRE.y + ry*(p.r + bpDist());
  const startOff = -((count-1)*pillStep())/2;
  return Array.from({length:count}, (_,i) => ({ x:ax, y:ay + startOff + i*pillStep() }));
}

// AAT pills: same y-values, horizontally offset inward
function aatPillPositions(boardId, count) {
  const bp = boardPillPositions(boardId, count);
  const p  = POS[boardId];
  const rx = Math.cos(toRad(p.angle-90));
  const ry = Math.sin(toRad(p.angle-90));
  let xOff;
  if (Math.abs(rx) > 0.2) xOff = rx > 0 ? -(pillW()+pillGap()) : (pillW()+pillGap());
  else xOff = ry < 0 ? (pillW()+pillGap()) : -(pillW()+pillGap());
  return bp.map(pos => ({ x: pos.x + xOff, y: pos.y }));
}

function singleColumnPositions(boardId, count) { return boardPillPositions(boardId, count); }

