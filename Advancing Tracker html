function renderBaseConnectors() {
  const g = document.getElementById('base-connectors');
  g.innerHTML = '';
  BASE_CONNECTIONS.forEach(c => {
    const from = getNodePos(c.from), to = getNodePos(c.to);
    const board = BOARDS.find(b => b.id === (c.to==='aat' ? c.from : c.to));
    const color = board ? CLUSTERS[board.cluster].color : '#CBD5E1';
    const isAat = c.from==='aat' || c.to==='aat';
    if (isAat) {
      g.appendChild(svgEl('line', {x1:from.x,y1:from.y,x2:to.x,y2:to.y,stroke:color,'stroke-width':2.5,opacity:0.4,class:'base-connector','data-from':c.from,'data-to':c.to}));
    } else {
      const mx=(from.x+to.x)/2, my=(from.y+to.y)/2;
      const cx=mx+(CENTRE.x-mx)*0.22, cy=my+(CENTRE.y-my)*0.22;
      g.appendChild(svgEl('path',{d:`M${from.x},${from.y} Q${cx},${cy} ${to.x},${to.y}`,fill:'none',stroke:color,'stroke-width':1.8,opacity:0.28,'stroke-dasharray':'6,4',class:'base-connector','data-from':c.from,'data-to':c.to}));
    }
  });
}

