// ══════════════════════════════════════════════════════════════════════
// HELPERS — missing field detection
// ══════════════════════════════════════════════════════════════════════
function isBlank(v) {
  if (v === null || v === undefined) return true;
  if (typeof v === 'string') {
    const t = v.trim().toLowerCase();
    return t === '' || t === 'tbc' || t === 'tbd' || t === 'n/a';
  }
  return false;
}

function countMissing(a) {
  let n = 0;
  const chk = (...vals) => vals.forEach(v => { if (isBlank(v)) n++; });
  chk(a.showTime, a.changeover, a.setDuration, a.loadIn, a.loadOut,
      a.soundcheckType, a.soundcheckTime, a.lightsCheck, a.dressingRoom,
      a.angel?.name, a.angel?.phone,
      a.hotelA?.name, a.hotelA?.checkInOut, a.hotelA?.breakfast,
      a.mealsAtHotel, a.riderLink, a.mealsOnSite,
      a.guestList, a.guestListDeadline, a.nightsTotal);
  if (a.drivingIn) chk(a.ownVehicle, a.parking, a.regPlates);
  a.transfers?.forEach(t => chk(t.time, t.driver, t.vehicle));
  return n;
}

// ══════════════════════════════════════════════════════════════════════
// PASSPHRASE AUTH
// ══════════════════════════════════════════════════════════════════════
function onPassInput(val) {
  document.getElementById('lock-error').textContent = '';
  document.getElementById('passphrase-input').classList.remove('error');
  const words = val.toLowerCase().replace(/[^a-z\-]/g, '').split('-').filter(w => w.length > 0);
  for (let i = 0; i < 4; i++) {
    const slot = document.getElementById('ws' + i);
    if (!slot) continue;
    if (words[i] !== undefined && words[i].length > 0) {
      slot.textContent = words[i];
      slot.className = 'word-slot ' + (i < words.length - 1 ? 'filled' : 'active');
    } else {
      slot.textContent = 'word';
      slot.className = 'word-slot';
    }
  }
}

function attemptUnlock() {
  const raw = document.getElementById('passphrase-input').value.trim().toLowerCase();
  const artist = ARTISTS.find(a => a.passphrase === raw);
  if (artist) {
    state.artist = artist;
    state.unlocked = true;
    const btn = document.querySelector('.unlock-btn');
    btn.textContent = 'Unlocked';
    btn.style.background = '#679436';
    setTimeout(() => {
      document.getElementById('lock-screen').classList.add('hidden');
      setTimeout(() => {
        document.getElementById('lock-screen').style.display = 'none';
        document.getElementById('app').style.display = 'block';
        loadArtist(artist);
      }, 500);
    }, 500);
  } else {
    const input = document.getElementById('passphrase-input');
    input.classList.add('error');
    document.getElementById('lock-error').textContent =
      raw.split('-').length < 4
        ? 'Passphrase must be four words separated by hyphens'
        : 'Passphrase not recognised — please check and try again';
    setTimeout(() => input.classList.remove('error'), 600);
  }
}

function lockScreen() {
  state.unlocked = false; state.artist = null;
  document.getElementById('app').style.display = 'none';
  const ls = document.getElementById('lock-screen');
  ls.style.display = 'flex';
  ls.classList.remove('hidden');
  const input = document.getElementById('passphrase-input');
  input.value = ''; input.classList.remove('error');
  document.getElementById('lock-error').textContent = '';
  onPassInput('');
  const btn = document.querySelector('.unlock-btn');
  btn.textContent = 'Access My Itinerary';
  btn.style.background = '';
  setTimeout(() => input.focus(), 100);
}

window.addEventListener('DOMContentLoaded', () => {
  setTimeout(() => document.getElementById('passphrase-input').focus(), 200);
});

// ══════════════════════════════════════════════════════════════════════
// LOAD ARTIST
// ══════════════════════════════════════════════════════════════════════

// Section colour vars indexed 1-5
const SEC_COLOURS = ['','#CA2E55','#337CA0','#FFD25A','#679436','#B3F2DD'];

function loadArtist(a) {
  document.getElementById('header-artist-name').textContent = a.name;
  document.getElementById('meta-show-date').textContent = a.showDate || '—';
  document.getElementById('meta-stage').textContent = a.stage || '—';
  document.getElementById('hero-name').textContent = a.name;
  document.getElementById('hero-date').textContent = a.showDateShort || '—';

  // Date block colour — cycle through palette
  document.getElementById('hero-date').style.color = 'var(--c1)';

  // Tags
  const heroTags = document.getElementById('hero-tags');
  heroTags.innerHTML = `
    <span class="tag tag-ink">${a.stage}</span>
    <span class="tag tag-c2">EC11 &nbsp;·&nbsp; 2025</span>
    ${a.drivingIn ? '<span class="tag tag-c4">Driving In</span>' : ''}
  `;

  // Alert bar
  const missing = countMissing(a);
  const alertBar = document.getElementById('alert-bar');
  alertBar.classList.toggle('visible', missing > 0);
  if (missing > 0) document.getElementById('missing-count-text').textContent = missing;

  document.getElementById('no-artist').style.display = 'none';
  document.getElementById('itinerary-view').style.display = 'block';
  renderSections(a);
}

// ══════════════════════════════════════════════════════════════════════
// FIELD ROW + GROUP BUILDERS
// ══════════════════════════════════════════════════════════════════════
function row(label, value, opts = {}) {
  const blank = isBlank(value);
  const cls = blank ? 'field-row missing' : 'field-row';
  const labelMark = blank ? `<span class="label-req">*</span>` : '';
  const valHTML = blank
    ? `<span class="missing-pill"><span class="missing-mark">!</span> Awaiting confirmation</span>`
    : (opts.html || value);
  return `<div class="${cls}">
    <div class="field-label">${labelMark}${label}</div>
    <div class="field-value">${valHTML}</div>
  </div>`;
}

function grp(label) {
  return `<div class="field-group-header">${label}</div>`;
}

// ══════════════════════════════════════════════════════════════════════
// SECTION SHELL — timeline node + card
// ══════════════════════════════════════════════════════════════════════
function makeSection(sNum, title, contentEl, missingCount) {
  const cls = 's' + sNum;
  const div = document.createElement('div');
  div.className = `section-block ${cls}`;
  div.id = `sb-${cls}`;

  const badge = missingCount > 0
    ? `<div class="node-badge visible">! ${missingCount}</div>`
    : '';

  div.innerHTML = `
    <div class="section-node">
      <div class="node-circle" onclick="toggleSection('${cls}')">
        <span class="node-num">${String(sNum).padStart(2,'0')}</span>
      </div>
      ${badge}
    </div>
    <div class="section-card" id="sc-${cls}">
      <div class="card-header" onclick="toggleSection('${cls}')">
        <div class="card-title">${title}</div>
        <div class="card-toggle">
          <span id="ct-label-${cls}">Collapse</span>
          <span class="toggle-chevron" id="ct-chev-${cls}">&#9660;</span>
        </div>
      </div>
      <div class="card-body" id="cb-${cls}"></div>
    </div>
  `;

  div.querySelector(`#cb-${cls}`).appendChild(contentEl);
  return div;
}

function toggleSection(cls) {
  state.collapsed[cls] = !state.collapsed[cls];
  const card = document.getElementById(`sc-${cls}`);
  const lbl  = document.getElementById(`ct-label-${cls}`);
  const chev = document.getElementById(`ct-chev-${cls}`);
  card.classList.toggle('collapsed', !!state.collapsed[cls]);
  if (lbl)  lbl.textContent  = state.collapsed[cls] ? 'Expand'   : 'Collapse';
  if (chev) chev.innerHTML   = state.collapsed[cls] ? '&#9654;' : '&#9660;';
}

// ══════════════════════════════════════════════════════════════════════
// RENDER
// ══════════════════════════════════════════════════════════════════════
function renderSections(a) {
  const c = document.getElementById('sections-container');
  c.innerHTML = '';
  c.appendChild(buildShow(a));
  c.appendChild(buildHotel(a));
  c.appendChild(buildHosp(a));
  c.appendChild(buildTransfers(a));
  c.appendChild(buildContacts(a));
}

// ── 01 SHOW & STAGE ───────────────────────────────────────────────
function buildShow(a) {
  const missing = [a.showTime, a.changeover, a.setDuration, a.loadIn, a.loadOut,
    a.soundcheckType, a.soundcheckTime, a.lightsCheck, a.dressingRoom,
    a.angel?.name, a.angel?.phone].filter(isBlank).length;

  const scHTML = !isBlank(a.soundcheckType) && !isBlank(a.soundcheckTime)
    ? `${a.soundcheckType} <span class="tag tag-c3" style="margin-left:6px;">${a.soundcheckTime}</span>`
    : null;

  const stageHTML = !isBlank(a.stage)
    ? `${a.stage} <span class="tag tag-ink" style="margin-left:6px;">Cap. ${a.capacity}</span>`
    : null;

  const div = document.createElement('div');
  div.innerHTML = `
    <div class="field-group">
      ${grp('Timings')}
      ${row('Show Date', a.showDate)}
      ${row('Show Time', a.showTime)}
      ${row('Changeover', a.changeover)}
      ${row('Set Duration', a.setDuration, { html: a.setDuration ? `${a.setDuration} min` : null })}
      ${row('Load In', a.loadIn)}
      ${row('Load Out', a.loadOut)}
    </div>
    <div class="field-group">
      ${grp('Production')}
      ${row('Stage', a.stage, { html: stageHTML })}
      ${row('Soundcheck', a.soundcheckType, { html: scHTML })}
      ${row('Lights Check', a.lightsCheck)}
      ${row('Overnight Programming', a.overnightProgramming)}
      ${row('Dressing Room', a.dressingRoom)}
    </div>
    <div class="field-group">
      ${grp('Your Angel — Dedicated On-site Liaison')}
      <div class="angel-block">
        <div class="angel-strip"></div>
        <div class="angel-inner">
          <div>
            <div class="angel-label">Angel</div>
            <div class="angel-name-disp">${isBlank(a.angel?.name)
              ? `<span class="missing-pill"><span class="missing-mark">!</span> * Not yet assigned</span>`
              : a.angel.name}</div>
          </div>
          <div class="angel-phone-disp">${isBlank(a.angel?.phone)
            ? `<span class="missing-pill" style="font-size:11px;"><span class="missing-mark">!</span> * Phone TBC</span>`
            : a.angel.phone}</div>
        </div>
      </div>
    </div>
  `;
  return makeSection(1, 'Show &amp; Stage', div, missing);
}

// ── 02 HOTEL ──────────────────────────────────────────────────────
function buildHotel(a) {
  const hA = a.hotelA || {};
  const hC = a.hotelCrew;

  function hmRow(label, val) {
    return `<div class="hmr">
      <span class="hmr-l">${label}</span>
      <span class="${isBlank(val) ? 'hmr-miss' : 'hmr-v'}">${isBlank(val) ? '* Awaiting' : val}</span>
    </div>`;
  }

  function hotelCol(hotel, type) {
    if (!hotel) return `<div class="hotel-col"><div class="hotel-col-type">${type}</div><div style="font-size:13px;color:var(--ink-soft);padding-top:4px;">No separate ${type.toLowerCase()} allocated.</div></div>`;
    return `<div class="hotel-col">
      <div class="hotel-col-type">${type}</div>
      <div class="hotel-name-disp">${isBlank(hotel.name)
        ? `<span class="missing-pill" style="font-size:11px;"><span class="missing-mark">!</span> * Not confirmed</span>`
        : hotel.name}</div>
      <div class="hotel-sub">${[hotel.type, hotel.address].filter(Boolean).join(' &mdash; ')}</div>
      <div class="hotel-mini">
        ${hmRow('Check In / Out', hotel.checkInOut)}
        ${hmRow('Breakfast', hotel.breakfast)}
        ${hmRow('Restaurant', hotel.restaurant)}
        ${hmRow('Room Service', hotel.roomService)}
        ${hmRow('Wellness', hotel.wellness)}
        ${hmRow('Laundry', hotel.laundry)}
      </div>
    </div>`;
  }

  const missing = [hA.name, hA.checkInOut, hA.breakfast, a.nightsTotal, a.mealsAtHotel].filter(isBlank).length;

  const div = document.createElement('div');
  div.innerHTML = `
    <div class="hotel-pair">
      ${hotelCol(hA, 'A-Party Hotel')}
      ${hotelCol(hC, 'Crew Hotel')}
    </div>
    <div class="field-group">
      ${grp('Stay Details')}
      ${row('Nights Total', a.nightsTotal)}
      ${row('Nights Paid by EC', a.nightsPaid)}
      ${row('Minibar', a.minibar)}
      ${row('Meals at Hotel', a.mealsAtHotel)}
      ${row('Incidentals', a.incidentals, { html: a.incidentals
        ? `${a.incidentals} <span style="font-size:11px;color:var(--ink-soft);margin-left:6px;">Early check-in / late checkout unavailable during festival</span>`
        : null })}
      ${row('Hotel Liaison', FESTIVAL.hotelLiaison, { html:
        `${FESTIVAL.hotelLiaison} &mdash; <a href="mailto:${FESTIVAL.hotelLiaisonEmail}" style="color:var(--c2);">${FESTIVAL.hotelLiaisonEmail}</a>` })}
    </div>
  `;
  return makeSection(2, 'Hotel &amp; Accommodation', div, missing);
}

// ── 03 HOSPITALITY ────────────────────────────────────────────────
function buildHosp(a) {
  const missing = [a.riderLink, a.mealsOnSite, a.guestList, a.guestListDeadline].filter(isBlank).length;
  const div = document.createElement('div');
  div.innerHTML = `
    <div class="field-group">
      ${grp('Rider & Catering')}
      ${row('Rider Alternatives Doc', a.riderLink, { html: a.riderLink
        ? `<a href="${a.riderLink}" target="_blank" style="color:var(--c2);font-weight:600;">View Rider Doc &#8599;</a>`
        : null })}
      ${row('Meals On-site', a.mealsOnSite)}
      ${row('Meals at Hotel', a.mealsAtHotel)}
    </div>
    <div class="field-group">
      ${grp('Press & Media')}
      ${row('Press / Interviews', a.interviews || 'None scheduled')}
    </div>
    <div class="field-group">
      ${grp('Guest List')}
      ${row('Guest List', a.guestList)}
      ${row('Submission Deadline', a.guestListDeadline)}
    </div>
    <div class="field-group">
      ${grp('Advancing Contacts')}
      ${row('Advancing Lead', a.advancingContact, { html: a.advancingContact
        ? `<strong>${a.advancingContact}</strong><span class="sub">${a.advancingEmail} &nbsp;·&nbsp; ${a.advancingPhone}</span>`
        : null })}
      ${row('Booking Contact', a.bookingContact, { html: a.bookingContact
        ? `<strong>${a.bookingContact}</strong><span class="sub">${a.bookingEmail}</span>`
        : null })}
    </div>
  `;
  return makeSection(3, 'On-site Hospitality', div, missing);
}

// ── 04 TRANSFERS ──────────────────────────────────────────────────
function buildTransfers(a) {
  let missing = 0;
  const tRows = (a.transfers || []).map((t, i) => {
    const timeMiss = isBlank(t.time);
    const driverMiss = isBlank(t.driver);
    if (timeMiss) missing++;
    if (driverMiss) missing++;
    const legCls = (timeMiss || driverMiss) ? 'field-row missing' : 'field-row';
    const labelMark = (timeMiss || driverMiss) ? '<span class="label-req">*</span>' : '';
    const timeChip = timeMiss
      ? `<span class="missing-pill" style="font-size:9px;"><span class="missing-mark">!</span> Time TBC</span>`
      : `<span class="tag tag-ink" style="font-size:9px;margin-left:4px;">${t.time}</span>`;
    return `<div class="${legCls}">
      <div class="field-label">${labelMark}Leg ${i+1} ${timeChip}</div>
      <div class="field-value" style="flex-direction:column;align-items:flex-start;gap:6px;">
        <div class="route">
          <div class="route-node">${t.from || '?'}</div>
          <div class="route-arr">&#8594;</div>
          <div class="route-node">${t.to || '?'}</div>
          <div class="route-dur">~${t.duration || 'TBC'}</div>
        </div>
        <div style="font-size:12px;color:var(--ink-soft);">
          Driver:&nbsp;${driverMiss
            ? `<span class="missing-pill" style="font-size:9px;"><span class="missing-mark">!</span> * Not yet assigned</span>`
            : `<strong style="color:var(--ink);">${t.driver}</strong>`}
          &nbsp;&mdash;&nbsp;
          ${isBlank(t.vehicle)
            ? `<span style="color:var(--alert);font-size:11px;">* Vehicle TBC</span>`
            : t.vehicle}
        </div>
      </div>
    </div>`;
  }).join('');

  const driveHTML = a.drivingIn ? `
    <div class="field-group">
      ${grp('Driving In — Details Required')}
      ${row('Own Vehicle', a.ownVehicle)}
      ${row('Parking', a.parking)}
      ${row('Registration Plates', a.regPlates)}
    </div>
  ` : '';
  if (a.drivingIn) [a.ownVehicle, a.parking, a.regPlates].forEach(v => { if(isBlank(v)) missing++; });

  const div = document.createElement('div');
  div.innerHTML = `
    <div class="field-group">
      ${grp('Scheduled Transfers')}
      ${tRows}
    </div>
    ${driveHTML}
    <div class="field-group">
      ${grp('Transport Contacts')}
      ${row('Transport Emergency', FESTIVAL.emergencyTransport, { html:
        `<strong>${FESTIVAL.emergencyTransport}</strong><span style="font-size:11px;color:var(--ink-soft);margin-left:8px;">24h emergency line</span>` })}
      ${row('Angel (after arrival)', a.angel?.name, { html: isBlank(a.angel?.name)
        ? null
        : `<strong>${a.angel.name}</strong>&nbsp;&nbsp;${a.angel.phone}` })}
      ${row('Advancing Lead (pre-arrival)', a.advancingContact, { html: a.advancingContact
        ? `${a.advancingContact}&nbsp;&mdash;&nbsp;${a.advancingPhone}` : null })}
    </div>
  `;
  return makeSection(4, 'Ground Transfers', div, missing);
}

// ── 05 CONTACTS ───────────────────────────────────────────────────
function buildContacts(a) {
  const cHTML = (a.contacts || []).map(c => `
    <div class="contact-block">
      <div class="cb-role">${c.role}</div>
      <div class="cb-name">${c.name || '—'}</div>
      <div class="cb-phone">${c.phone || '—'}</div>
      <div class="cb-email">${c.email || '—'}</div>
    </div>
  `).join('');

  const div = document.createElement('div');
  div.innerHTML = `
    <div class="field-group">
      ${grp('EC On-site Team — CC your advancing contact in all correspondence')}
      <div class="contacts-grid">${cHTML}</div>
    </div>
    <div class="field-group">
      ${grp('Festival Information')}
      ${row('Website', 'electriccastle.ro', { html: '<a href="https://electriccastle.ro" target="_blank" style="color:var(--c2);font-weight:600;">electriccastle.ro &#8599;</a>' })}
      ${row('Location', FESTIVAL.location, { html: `${FESTIVAL.location}&nbsp;&nbsp;<a href="https://maps.google.com/?q=Banffy+Castle+Bontida" target="_blank" style="color:var(--c2);">Open in Maps &#8599;</a>` })}
      ${row('Airport', FESTIVAL.airport)}
      ${row('Artist Pack (Google Drive)', '—', { html: '<span style="color:var(--ink-soft);font-style:italic;font-weight:300;">Link provided by your advancing contact</span>' })}
    </div>
  `;
  return makeSection(5, 'Contacts', div, 0);
}
