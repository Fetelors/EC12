<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>EC11 — Artist Itinerary</title>
<link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800;900&family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>

<style>
/* ══════════════════════════════════════════════════════════════
   PALETTE
   ══════════════════════════════════════════════════════════════ */
:root {
  /* Brand palette */
  --rosewood:     #CA2E55;
  --cerulean:     #337CA0;
  --pollen:       #FFD25A;
  --sage:         #679436;
  --aqua:         #B3F2DD;

  /* Section colours — 5 sections, 5 colours */
  --c1: #CA2E55;  /* Show & Stage     — Rosewood  */
  --c2: #337CA0;  /* Hotel            — Cerulean  */
  --c3: #FFD25A;  /* Hospitality      — Pollen    */
  --c4: #679436;  /* Transfers        — Sage      */
  --c5: #B3F2DD;  /* Contacts         — Icy Aqua  */

  /* Section text — some light backgrounds need dark text */
  --c1-text: #ffffff;
  --c2-text: #ffffff;
  --c3-text: #1C1A16;   /* dark on yellow */
  --c4-text: #ffffff;
  --c5-text: #1C1A16;   /* dark on aqua  */

  /* Muted section bg tints */
  --c1-tint: #fdf0f3;
  --c2-tint: #f0f6fa;
  --c3-tint: #fffbee;
  --c4-tint: #f2f7ec;
  --c5-tint: #f0fdf8;

  /* Neutral */
  --bg:       #F7F8FA;
  --white:    #FFFFFF;
  --ink:      #1C1A16;
  --ink-mid:  #3D3A35;
  --ink-soft: #858180;
  --rule:     #E4E2DE;

  /* Alert — missing fields */
  --alert:       #CA2E55;
  --alert-light: #fdf0f3;

  /* Spine */
  --spine: #DDD9D4;
  --spine-w: 2px;
  --spine-x: 52px;   /* left offset of spine within main */

  /* Typography */
  --ff-head: 'Raleway', sans-serif;
  --ff-body: 'Sora', sans-serif;
}

/* ══════════════════════════════════════════════════════════════
   RESET
   ══════════════════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--ff-body);
  background: var(--bg);
  color: var(--ink);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ══════════════════════════════════════════════════════════════
   LOCK SCREEN
   ══════════════════════════════════════════════════════════════ */
#lock-screen {
  position: fixed; inset: 0;
  background: var(--ink);
  display: flex; align-items: center; justify-content: center;
  z-index: 1000;
  transition: opacity 0.5s ease;
}
#lock-screen.hidden { opacity: 0; pointer-events: none; }

.lock-card {
  background: #242018;
  width: 92%; max-width: 440px;
  padding: 52px 52px 44px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

/* Decorative colour strip at top of lock card */
.lock-stripe {
  position: absolute; top: 0; left: 0; right: 0;
  height: 5px;
  display: flex;
}
.lock-stripe span {
  flex: 1;
}
.lock-stripe span:nth-child(1) { background: var(--rosewood); }
.lock-stripe span:nth-child(2) { background: var(--cerulean); }
.lock-stripe span:nth-child(3) { background: var(--pollen); }
.lock-stripe span:nth-child(4) { background: var(--sage); }
.lock-stripe span:nth-child(5) { background: var(--aqua); }

.lock-eyebrow {
  font-family: var(--ff-head);
  font-size: 10px; font-weight: 700;
  letter-spacing: 4px; text-transform: uppercase;
  color: rgba(255,255,255,0.25);
  margin-bottom: 14px;
}

.lock-title {
  font-family: var(--ff-head);
  font-size: 34px; font-weight: 800;
  color: #F7F8FA; line-height: 1;
  margin-bottom: 6px;
}

.lock-title-accent { color: var(--cerulean); }

.lock-sub {
  font-size: 13px; font-weight: 300;
  color: rgba(255,255,255,0.35);
  line-height: 1.6; margin-bottom: 40px;
}

/* Word preview slots */
.word-slots {
  display: flex; gap: 6px; justify-content: center;
  margin-bottom: 16px; flex-wrap: wrap;
}
.word-slot {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 4px;
  padding: 5px 12px;
  font-family: var(--ff-body);
  font-size: 11px; font-weight: 500;
  color: rgba(255,255,255,0.18);
  letter-spacing: 0.4px;
  min-width: 76px; text-align: center;
  transition: all 0.2s;
}
.word-slot.active { border-color: var(--cerulean); color: #F7F8FA; background: rgba(51,124,160,0.15); }
.word-slot.filled { border-color: rgba(51,124,160,0.4); color: rgba(51,124,160,0.85); background: rgba(51,124,160,0.06); }

/* Input */
.passphrase-input {
  width: 100%;
  background: rgba(255,255,255,0.05);
  border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 6px;
  color: #F7F8FA;
  font-family: var(--ff-body);
  font-size: 15px; font-weight: 400;
  padding: 14px 18px;
  outline: none;
  transition: border-color 0.2s;
  text-align: center;
  letter-spacing: 0.3px;
  margin-bottom: 12px;
}
.passphrase-input::placeholder { color: rgba(255,255,255,0.18); font-weight: 300; }
.passphrase-input:focus { border-color: var(--cerulean); }
.passphrase-input.error { border-color: var(--rosewood); animation: shake 0.35s ease; }

.lock-error {
  font-size: 12px; color: #E0889A;
  height: 16px; margin-bottom: 10px;
}

.unlock-btn {
  width: 100%;
  background: var(--cerulean);
  border: none; border-radius: 6px;
  color: #fff;
  font-family: var(--ff-head);
  font-size: 12px; font-weight: 800;
  padding: 15px; cursor: pointer;
  transition: all 0.15s;
  letter-spacing: 2px; text-transform: uppercase;
}
.unlock-btn:hover { background: #2a6884; }

.lock-hint {
  margin-top: 24px;
  font-size: 11px; font-weight: 300;
  color: rgba(255,255,255,0.18); line-height: 1.7;
}
.lock-hint code {
  font-family: var(--ff-body);
  background: rgba(255,255,255,0.05);
  padding: 1px 6px; border-radius: 3px;
  color: rgba(255,255,255,0.28);
}

@keyframes shake {
  0%,100%{transform:translateX(0)} 20%{transform:translateX(-6px)}
  40%{transform:translateX(6px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(4px)}
}

/* ══════════════════════════════════════════════════════════════
   APP HEADER
   ══════════════════════════════════════════════════════════════ */
.app-header {
  background: var(--white);
  border-bottom: 1px solid var(--rule);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 16px rgba(0,0,0,0.07);
}

/* Five-colour stripe across very top */
.colour-stripe {
  display: flex; height: 4px;
}
.colour-stripe span { flex: 1; }
.colour-stripe span:nth-child(1) { background: var(--c1); }
.colour-stripe span:nth-child(2) { background: var(--c2); }
.colour-stripe span:nth-child(3) { background: var(--c3); }
.colour-stripe span:nth-child(4) { background: var(--c4); }
.colour-stripe span:nth-child(5) { background: var(--c5); }

.header-inner {
  max-width: 1120px; margin: 0 auto;
  padding: 20px 40px;
  display: flex; align-items: center;
  justify-content: space-between;
  gap: 20px; flex-wrap: wrap;
}

.brand {
  display: flex; align-items: center; gap: 14px;
}
.brand-circles {
  display: flex; gap: -4px;
}
.brand-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  margin-right: -3px;
  border: 2px solid var(--white);
}
.brand-dot:nth-child(1) { background: var(--c1); z-index: 5; }
.brand-dot:nth-child(2) { background: var(--c2); z-index: 4; }
.brand-dot:nth-child(3) { background: var(--c3); z-index: 3; }
.brand-dot:nth-child(4) { background: var(--c4); z-index: 2; }
.brand-dot:nth-child(5) { background: var(--c5); z-index: 1; }

.brand-label {}
.brand-eyebrow {
  font-family: var(--ff-head);
  font-size: 9px; font-weight: 700;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--ink-soft); margin-bottom: 2px;
}
.brand-title {
  font-family: var(--ff-head);
  font-size: 20px; font-weight: 800;
  color: var(--ink); line-height: 1;
}

.header-right { display: flex; align-items: center; gap: 16px; }

.header-artist-pill {
  display: flex; align-items: center; gap: 10px;
  background: var(--bg);
  border: 1px solid var(--rule);
  border-radius: 100px;
  padding: 8px 16px 8px 12px;
}
.hap-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--c1); flex-shrink: 0;
}
.hap-label {
  font-size: 10px; font-weight: 600;
  letter-spacing: 1px; text-transform: uppercase;
  color: var(--ink-soft);
}
.hap-name {
  font-family: var(--ff-head);
  font-size: 14px; font-weight: 700;
  color: var(--ink);
}

.lock-btn {
  background: transparent;
  border: 1px solid var(--rule);
  border-radius: 6px;
  color: var(--ink-soft);
  font-family: var(--ff-head);
  font-size: 10px; font-weight: 700;
  padding: 9px 16px; cursor: pointer;
  transition: all 0.15s;
  letter-spacing: 1px; text-transform: uppercase;
}
.lock-btn:hover { border-color: var(--ink-soft); color: var(--ink); }

/* Meta bar */
.meta-bar {
  background: var(--bg);
  border-top: 1px solid var(--rule);
}
.meta-inner {
  max-width: 1120px; margin: 0 auto;
  padding: 10px 40px;
  display: flex; align-items: center;
  gap: 0; flex-wrap: wrap;
}
.meta-item {
  display: flex; align-items: center; gap: 8px;
  padding: 0 20px 0 0; margin-right: 20px;
  border-right: 1px solid var(--rule);
}
.meta-item:last-child { border-right: none; }
.meta-label {
  font-size: 9px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--ink-soft);
}
.meta-value {
  font-size: 12px; font-weight: 500; color: var(--ink-mid);
}

/* Alert bar */
.alert-bar {
  background: var(--rosewood); display: none;
}
.alert-bar.visible { display: block; }
.alert-inner {
  max-width: 1120px; margin: 0 auto;
  padding: 10px 40px;
  display: flex; align-items: center; gap: 12px;
}
.alert-excl {
  width: 20px; height: 20px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.6);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 900; color: #fff;
  flex-shrink: 0;
}
.alert-text {
  font-size: 12px; font-weight: 500;
  color: rgba(255,255,255,0.9); line-height: 1.4;
}
.alert-text strong { color: #fff; }

/* ══════════════════════════════════════════════════════════════
   MAIN — TIMELINE LAYOUT
   ══════════════════════════════════════════════════════════════ */
.main {
  max-width: 1120px; margin: 0 auto;
  padding: 48px 40px 100px;
  position: relative;
}

/* VERTICAL SPINE LINE */
.main::before {
  content: '';
  position: absolute;
  left: calc(40px + var(--spine-x));
  top: 48px; bottom: 100px;
  width: var(--spine-w);
  background: var(--spine);
  pointer-events: none;
}

/* ── Artist Hero ─────────────────────────────────────────── */
.artist-hero {
  padding-left: calc(var(--spine-x) + 32px + 32px);
  margin-bottom: 52px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20px; flex-wrap: wrap;
}

.hero-name {
  font-family: var(--ff-head);
  font-size: 56px; font-weight: 900;
  color: var(--ink); line-height: 1;
  letter-spacing: -1.5px;
}

.hero-tags {
  display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap;
}

.tag {
  font-family: var(--ff-head);
  font-size: 10px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  padding: 4px 12px; border-radius: 100px;
}
.tag-ink { background: var(--ink); color: var(--white); }
.tag-c1  { background: var(--c1); color: #fff; }
.tag-c2  { background: var(--c2); color: #fff; }
.tag-c3  { background: var(--c3); color: var(--c3-text); }
.tag-c4  { background: var(--c4); color: #fff; }
.tag-c5  { background: var(--c5); color: var(--c5-text); }
.tag-alert { background: var(--alert); color: #fff; }

.hero-date-block {
  text-align: right; flex-shrink: 0;
}
.hdb-day {
  font-family: var(--ff-head);
  font-size: 52px; font-weight: 900;
  line-height: 1;
}
.hdb-sub {
  font-size: 10px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--ink-soft); margin-top: 4px;
}

/* ── Section block — timeline node + card ────────────────── */
.sections { display: flex; flex-direction: column; gap: 24px; }

.section-block {
  display: flex;
  align-items: flex-start;
  gap: 0;
}

/* Left column: spine node */
.section-node {
  width: calc(var(--spine-x) + 32px);
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 28px;
  position: relative;
}

/* Circle number */
.node-circle {
  width: 64px; height: 64px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  position: relative;
  flex-shrink: 0;
  z-index: 2;
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
}
.node-circle:hover { transform: scale(1.06); box-shadow: 0 4px 20px rgba(0,0,0,0.15); }

.section-block.s1 .node-circle { background: var(--c1); }
.section-block.s2 .node-circle { background: var(--c2); }
.section-block.s3 .node-circle { background: var(--c3); }
.section-block.s4 .node-circle { background: var(--c4); }
.section-block.s5 .node-circle { background: var(--c5); }

.node-num {
  font-family: var(--ff-head);
  font-size: 22px; font-weight: 900;
  line-height: 1; letter-spacing: -0.5px;
}
.section-block.s1 .node-num,
.section-block.s2 .node-num,
.section-block.s4 .node-num { color: #fff; }
.section-block.s3 .node-num,
.section-block.s5 .node-num { color: var(--ink); }

/* Connector line: horizontal, from circle to card */
.node-connector {
  position: absolute;
  top: 60px; /* align to circle centre */
  left: 32px; /* start at circle edge */
  height: 2px;
  background: var(--spine);
  width: 32px;
  z-index: 1;
}

/* Missing badge on node */
.node-badge {
  margin-top: 8px;
  font-family: var(--ff-head);
  font-size: 9px; font-weight: 800;
  letter-spacing: 0.5px; text-transform: uppercase;
  color: var(--alert);
  background: var(--alert-light);
  padding: 2px 8px; border-radius: 100px;
  white-space: nowrap;
  display: none;
}
.node-badge.visible { display: block; }

/* Right column: content card */
.section-card {
  flex: 1;
  background: var(--white);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  margin-left: 32px;
  border-top: 4px solid transparent;
  transition: box-shadow 0.2s;
}
.section-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.1); }

.section-block.s1 .section-card { border-top-color: var(--c1); }
.section-block.s2 .section-card { border-top-color: var(--c2); }
.section-block.s3 .section-card { border-top-color: var(--c3); }
.section-block.s4 .section-card { border-top-color: var(--c4); }
.section-block.s5 .section-card { border-top-color: var(--c5); }

/* Card header */
.card-header {
  display: flex; align-items: center;
  justify-content: space-between;
  padding: 18px 24px 14px;
  cursor: pointer; user-select: none;
  border-bottom: 1px solid var(--rule);
}

.card-title {
  font-family: var(--ff-head);
  font-size: 16px; font-weight: 800;
  color: var(--ink); letter-spacing: 0.2px;
}

.card-toggle {
  font-family: var(--ff-head);
  font-size: 10px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--ink-soft);
  display: flex; align-items: center; gap: 6px;
}

.toggle-chevron {
  display: inline-block;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: var(--bg);
  border: 1px solid var(--rule);
  display: flex; align-items: center; justify-content: center;
  font-size: 8px; color: var(--ink-soft);
  transition: transform 0.2s;
}

.section-card.collapsed .toggle-chevron { transform: rotate(-90deg); }

.card-body { display: block; }
.section-card.collapsed .card-body { display: none; }

/* ══════════════════════════════════════════════════════════════
   FIELD ROWS
   ══════════════════════════════════════════════════════════════ */
.field-group { border-bottom: 1px solid var(--rule); }
.field-group:last-child { border-bottom: none; }

.field-group-header {
  padding: 8px 24px;
  font-family: var(--ff-head);
  font-size: 8px; font-weight: 800;
  letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--ink-soft);
  background: var(--bg);
  border-bottom: 1px solid var(--rule);
}

.field-row {
  display: grid;
  grid-template-columns: 210px 1fr;
  border-bottom: 1px solid var(--rule);
  min-height: 44px;
}
.field-row:last-child { border-bottom: none; }

.field-label {
  padding: 12px 16px 12px 24px;
  font-family: var(--ff-head);
  font-size: 11px; font-weight: 700;
  color: var(--ink-soft);
  border-right: 1px solid var(--rule);
  display: flex; align-items: center; gap: 6px;
  line-height: 1.3; letter-spacing: 0.2px;
}

.label-req {
  font-size: 16px; font-weight: 900;
  color: var(--alert); line-height: 1;
  flex-shrink: 0;
}

.field-value {
  padding: 12px 24px;
  font-size: 13px; font-weight: 400;
  color: var(--ink-mid);
  display: flex; align-items: center;
  gap: 8px; flex-wrap: wrap; line-height: 1.5;
}
.field-value strong { color: var(--ink); font-weight: 600; }
.field-value .sub {
  font-size: 11px; color: var(--ink-soft);
  display: block; margin-top: 1px; width: 100%;
}

/* Missing row state */
.field-row.missing .field-label {
  background: var(--alert-light);
  border-right-color: #f5c6c2;
  color: var(--alert);
}
.field-row.missing .field-value {
  background: var(--alert-light);
}

.missing-pill {
  display: inline-flex; align-items: center; gap: 5px;
  background: var(--alert);
  color: #fff;
  font-family: var(--ff-head);
  font-size: 10px; font-weight: 700;
  padding: 3px 10px; border-radius: 100px;
  letter-spacing: 0.5px; text-transform: uppercase;
}
.missing-mark { font-size: 12px; font-weight: 900; }

/* ══════════════════════════════════════════════════════════════
   SPECIAL COMPONENTS
   ══════════════════════════════════════════════════════════════ */

/* Angel block */
.angel-block {
  display: flex; align-items: stretch;
  border-top: 1px solid var(--rule);
}
.angel-strip {
  width: 5px; flex-shrink: 0;
}
.section-block.s1 .angel-strip { background: var(--c1); }

.angel-inner {
  flex: 1; padding: 16px 24px;
  display: flex; align-items: center;
  justify-content: space-between;
  flex-wrap: wrap; gap: 12px;
}
.angel-label {
  font-family: var(--ff-head);
  font-size: 8px; font-weight: 800;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--ink-soft); margin-bottom: 3px;
}
.angel-name-disp {
  font-family: var(--ff-head);
  font-size: 17px; font-weight: 700; color: var(--ink);
}
.angel-phone-disp {
  font-family: var(--ff-head);
  font-size: 17px; font-weight: 700; color: var(--c1);
}

/* Hotel pair */
.hotel-pair {
  display: grid; grid-template-columns: 1fr 1fr;
  border-top: 1px solid var(--rule);
}
.hotel-col {
  padding: 20px 24px;
  border-right: 1px solid var(--rule);
}
.hotel-col:last-child { border-right: none; }
.hotel-col-type {
  font-family: var(--ff-head);
  font-size: 8px; font-weight: 800;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--ink-soft); margin-bottom: 6px;
  display: flex; align-items: center; gap: 8px;
}
.hotel-name-disp {
  font-family: var(--ff-head);
  font-size: 17px; font-weight: 700; color: var(--ink);
  margin-bottom: 2px;
}
.hotel-sub {
  font-size: 11px; color: var(--ink-soft); margin-bottom: 12px;
}
.hotel-mini { display: flex; flex-direction: column; gap: 0; }
.hmr {
  display: flex; justify-content: space-between;
  align-items: baseline; gap: 12px;
  padding: 5px 0;
  border-bottom: 1px dashed var(--rule);
  font-size: 12px;
}
.hmr:last-child { border-bottom: none; }
