  // Legend strip
  const legendHtml = `<div class="panel-legend">
    <span class="panel-legend-item"><span class="action-source monday">MON</span> Auto from Monday</span>
    <span class="panel-legend-item"><span class="action-source email">EMAIL</span> Auto from Email Tool</span>
    <span class="panel-legend-item"><span class="action-source manual">MANUAL</span> Manual checkbox</span>
    <span class="panel-legend-item" style="margin-left:4px">⚡ = conflict with Monday data</span>
  </div>`;

  const sectionsHtml = ACTION_STEPS
    .filter(step => step.num <= effectiveCurrent)
    .map(step => {
      const isPast    = step.num < effectiveCurrent;
      const isCurrent = step.num === effectiveCurrent;
      const isOpen    = !!ST.stepOpen[step.num];

      // Tally using resolved ticks
      const resolved = step.actions.map((_, i) => resolveActionTick(a, step.num, i));
      const checkedCount = resolved.filter(r => r.ticked).length;
      const conflictCount = resolved.filter(r => r.conflict).length;
      const overdueCount  = isPast ? resolved.filter(r => !r.ticked).length : 0;
      const total = step.actions.length;
      const pct   = total ? Math.round((checkedCount / total) * 100) : 0;

      // Header badge
      let badgeHtml = '';
      if (conflictCount > 0) {
        badgeHtml += `<span class="step-pending-badge red">⚡ ${conflictCount} conflict${conflictCount > 1 ? 's':''}</span> `;
      }
      if (overdueCount > 0) {
        const sev = overdueCount >= 3 ? 'red' : '';
        badgeHtml += `<span class="step-pending-badge ${sev}">${overdueCount} pending</span>`;
      } else if (isPast && checkedCount === total) {
        badgeHtml += `<span class="step-done-badge">✓ All done</span>`;
      } else if (isCurrent) {
        badgeHtml += `<span style="font-size:9px;color:var(--text-soft)">${checkedCount}/${total}</span>`;
      }

      const numCls = isCurrent ? 'current' : (checkedCount === total ? 'done' : 'past');

      // Source badge labels
      const SRC_LABELS = { monday: 'MON', email: 'EMAIL', manual: 'MANUAL' };

      const actionsHtml = step.actions.map((act, i) => {
        const r       = resolved[i];
        const overdue = isPast && !r.ticked;
        const srcCls  = act.source;
        const srcLbl  = SRC_LABELS[act.source];

        // Tooltip for monday actions: shows column name + board
        const tip = act.source === 'monday'
          ? `title="Monday: ${esc(act.columnName)} (${esc(act.boardRef)} board) · condition: ${esc(act.condition)}"`
          : act.source === 'email'
          ? `title="Email Tool: module ${esc(act.emailModule)}"`
          : '';

        // Conflict icon
        const conflictIcon = r.conflict
          ? `<span class="action-conflict-icon" title="Conflict: Monday says ${r.autoTick ? '✓ ticked' : '✗ unticked'} but manually overridden">⚡</span>`
          : '';

        return `<div class="action-item ${r.ticked ? 'checked':''} ${overdue ? 'overdue':''} ${r.conflict ? 'conflict':''}"
                     onclick="toggleAction('${esc(a.id)}', ${step.num}, ${i})" ${tip}>
          <div class="action-check"></div>
          <span class="action-label">${esc(act.label)}</span>
          ${conflictIcon}
          <span class="action-source ${srcCls}">${srcLbl}</span>
          <span class="action-owner ${act.owner}">${act.owner.toUpperCase()}</span>
        </div>`;
      }).join('');

      return `<div class="step-section ${isOpen ? 'expanded' : ''}" id="ps-${step.num}">
        <div class="step-section-hd" onclick="togglePanelStep(${step.num})">
          <div class="step-num-badge ${numCls}">${step.num}</div>
          <div class="step-section-name">
            ${esc(step.name)}
            <span class="step-owner-badge ${step.owner}">${step.owner.toUpperCase()}</span>
          </div>
          <div class="step-section-right">
            ${badgeHtml}
            <span class="step-toggle-arrow">▼</span>
          </div>
        </div>
        <div class="action-list">
          <div class="step-progress-bar">
            <div class="step-progress-fill" style="width:${pct}%"></div>
          </div>
          ${actionsHtml}
        </div>
      </div>`;
    }).join('');

  body.innerHTML = legendHtml + sectionsHtml;
}

// ── RENDER ALL ────────────────────────────────────────────────
function renderAll() {
  renderStats();
  renderLeadPills();
  renderBookedByPills();
  if (ST.view === 'pipeline') renderPipeline();
  else if (ST.view === 'blockers') renderBlockers();
  else if (ST.view === 'bylead') renderByLead();
}

// ── VIEW & FILTER CONTROLS ────────────────────────────────────
function setView(v) {
  ST.view = v;
  document.querySelectorAll('.view').forEach(el => el.classList.remove('active'));
  document.getElementById('view-' + v).classList.add('active');
  document.querySelectorAll('.view-tab').forEach(t => t.classList.toggle('active', t.dataset.view === v));
  renderAll();
}

function setFilter(type, val) {
  ST.filters[type] = val;
  document.querySelectorAll(`.filter-pill[data-filter="${type}"]`).forEach(p => {
    p.classList.toggle('active', p.dataset.val === val);
  });
  renderAll();
}

function handleSearch(v) { ST.search = v; renderPipeline(); }

function toggleBlocker(id) {
  ST.blockerOpen[id] = !ST.blockerOpen[id];
  renderBlockers();
}

function toggleLead(lead) {
  ST.leadOpen[lead] = !ST.leadOpen[lead];
  renderByLead();
}

// ── SETTINGS ─────────────────────────────────────────────────
function loadCfg() {
  try {
    const s = JSON.parse(localStorage.getItem('ec12_cfg') || '{}');
    Object.assign(CFG, s);
    if (s.cols)     CFG.cols     = Object.assign({}, CFG.cols, s.cols);
    if (s.boardIds) CFG.boardIds = Object.assign({}, CFG.boardIds, s.boardIds);
  } catch(e) {}
  document.getElementById('event-subtitle').textContent = CFG.eventName;
}

function openSettings() {
  document.getElementById('cfg-apikey').value     = CFG.apiKey;
  document.getElementById('cfg-boardid').value    = CFG.boardId;
  document.getElementById('cfg-workspace').value  = CFG.workspaceUrl;
  document.getElementById('cfg-eventname').value  = CFG.eventName;
  Object.entries(CFG.cols).forEach(([k,v]) => {
    const el = document.getElementById('col-'+k);
    if (el) el.value = v;
  });
  Object.entries(CFG.boardIds).forEach(([k,v]) => {
    const el = document.getElementById('bid-'+k);
    if (el) el.value = v || '';
  });
  document.getElementById('settings-overlay').classList.add('open');
}

function closeSettings() {
  document.getElementById('settings-overlay').classList.remove('open');
}

function saveSettings() {
  CFG.apiKey       = document.getElementById('cfg-apikey').value.trim();
  CFG.boardId      = document.getElementById('cfg-boardid').value.trim();
  CFG.workspaceUrl = document.getElementById('cfg-workspace').value.trim().replace(/^https?:\/\//,'');
  CFG.eventName    = document.getElementById('cfg-eventname').value.trim() || 'Electric Castle · EC12';
  ['tier','lead','bookedBy','origin','s0','s1','s2','s3','s4','s5','s6','s7','rider','party','hotel','dietary'].forEach(k => {
    const el = document.getElementById('col-'+k);
    if (el) CFG.cols[k] = el.value.trim();
  });
  Object.keys(CFG.boardIds).forEach(k => {
    const el = document.getElementById('bid-'+k);
    if (el) CFG.boardIds[k] = el.value.trim();
  });
  // Keep artist board ID in sync with main boardId
  if (!CFG.boardIds.artist) CFG.boardIds.artist = CFG.boardId;
  localStorage.setItem('ec12_cfg', JSON.stringify(CFG));
  document.getElementById('event-subtitle').textContent = CFG.eventName;
  closeSettings();
  refreshData();
}

// ── DATA LOAD ─────────────────────────────────────────────────
async function refreshData() {
  showLoader(true);
  const data = await fetchMonday();
  if (data && data.length > 0) {
    ST.artists  = data;
    ST.sync     = 'live';
    ST.syncTime = new Date().toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });
  } else {
    ST.artists = MOCK_ARTISTS;
    ST.sync    = (CFG.apiKey && CFG.boardId) ? 'error' : 'offline';
  }
  renderAll();
  showLoader(false);
}

function showLoader(v) { document.getElementById('loader').style.display = v ? 'flex' : 'none'; }

// ── UTILITY ───────────────────────────────────────────────────
function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

// ── EVENT DELEGATION ──────────────────────────────────────────
document.querySelectorAll('.view-tab').forEach(t =>
  t.addEventListener('click', () => setView(t.dataset.view)));

document.querySelectorAll('.filter-pill[data-filter]').forEach(p =>
  p.addEventListener('click', () => setFilter(p.dataset.filter, p.dataset.val)));

// Close modal on overlay click
document.getElementById('settings-overlay').addEventListener('click', function(e) {
  if (e.target === this) closeSettings();
});

// ── INIT ──────────────────────────────────────────────────────
loadCfg();
refreshData();
</script>
</body>
</html>
