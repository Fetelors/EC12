<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>EC12 — Hospitality Manager</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>

/* ── RESET ──────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 14px; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--text);
  min-height: 100vh;
}

/* ── PALETTE ────────────────────────────────────────────────── */
/* Edit this block to retheme the entire app. No hex codes appear anywhere else. */
:root {
  /* Primary — deep festival navy */
  --primary:        #1A2942;
  --primary-mid:    #243656;
  --primary-dark:   #0F1E35;
  --primary-light:  #3D5A8A;
  --primary-pale:   #E8EEF7;

  /* Background — warm off-white */
  --cream:      #F4F1EB;
  --cream-dark: #E5DFD3;

  /* Accent A — coral / blocked / alert */
  --accent-a:       #C85A45;
  --accent-a-light: #FAECE9;

  /* Accent B — amber / in progress / warn */
  --accent-b:       #B87010;
  --accent-b-light: #FEF3C7;

  /* Accent C — green / complete / good */
  --accent-c:       #1A7A50;
  --accent-c-light: #D1FAE5;

  /* Accent D — blue / info */
  --accent-d:       #2558C9;
  --accent-d-light: #DBEAFE;

  /* Tier colours */
  --tier-headliner-col: #6D3AC9;
  --tier-headliner-bg:  #F0EBFF;
  --tier-sub-col:       #2558C9;
  --tier-sub-bg:        #EBF1FF;
  --tier-support-col:   #1A7A50;
  --tier-support-bg:    #E8F7F1;
  --tier-local-col:     #6B7280;
  --tier-local-bg:      #F3F4F6;

  /* Origin colours */
  --origin-int-col:   #1A2942;
  --origin-int-bg:    #DDE4F0;
  --origin-ro-col:    #7A3A0A;
  --origin-ro-bg:     #FDE8CC;
  --origin-local-col: #374151;
  --origin-local-bg:  #E5E7EB;

  /* Text scale */
  --text:      #16213A;
  --text-mid:  #4A5568;
  --text-soft: #8B95A8;
  --text-inv:  #EEF2FF;

  /* Borders */
  --border:      #D8D2C6;
  --border-dark: #BDB7A8;
}

/* ── LOADER ─────────────────────────────────────────────────── */
#loader {
  position: fixed; inset: 0;
  background: rgba(15, 30, 53, 0.92);
  z-index: 9999;
  display: none;
  flex-direction: column; align-items: center; justify-content: center; gap: 16px;
}
#loader .spin {
  width: 34px; height: 34px;
  border: 3px solid rgba(255,255,255,0.12);
  border-top-color: #5B8FD4;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
#loader p { color: rgba(240,242,255,0.5); font-size: 11px; letter-spacing: 0.5px; }

/* ── APP HEADER (3-bar stack) ───────────────────────────────── */
.app-header { position: sticky; top: 0; z-index: 100; }

/* Bar 1 — Identity */
.header-bar {
  background: var(--primary);
  padding: 12px 20px;
  display: flex; align-items: center; justify-content: space-between;
}
.header-identity { display: flex; align-items: baseline; gap: 14px; }
.header-title {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  color: var(--text-inv);
  letter-spacing: -0.3px;
}
.header-subtitle {
  font-size: 10px;
  color: rgba(238,242,255,0.4);
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 1.2px;
}
.header-actions { display: flex; gap: 8px; }
.header-btn {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.1);
  color: rgba(238,242,255,0.6);
  font-family: 'DM Sans', sans-serif;
  font-size: 11px; font-weight: 500;
  padding: 5px 12px; border-radius: 6px;
  cursor: pointer; transition: all 0.15s;
}
.header-btn:hover { background: rgba(255,255,255,0.14); color: white; }
.header-btn.accent {
  background: var(--primary-light);
  border-color: transparent;
  color: white;
}
.header-btn.accent:hover { background: #4D6FA0; }

/* Bar 2 — Context (view tabs + filters) */
.context-bar {
  background: var(--primary-mid);
  padding: 0 20px;
  display: flex; align-items: stretch; justify-content: space-between; gap: 12px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  overflow-x: auto;
}
.context-bar::-webkit-scrollbar { display: none; }

/* View tabs */
.view-tabs { display: flex; flex-shrink: 0; }
.view-tab {
  background: none; border: none;
  color: rgba(238,242,255,0.45);
  font-family: 'DM Sans', sans-serif;
  font-size: 12px; font-weight: 500;
  padding: 13px 18px;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.15s;
  white-space: nowrap;
}
.view-tab:hover { color: rgba(238,242,255,0.8); }
.view-tab.active { color: white; border-bottom-color: #5B8FD4; }

/* Filters */
.filter-row {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 0; flex-wrap: nowrap;
  overflow-x: auto; flex: 1;
}
.filter-row::-webkit-scrollbar { display: none; }
.filter-label {
  font-size: 9px; font-weight: 600;
  color: rgba(238,242,255,0.28);
  text-transform: uppercase; letter-spacing: 0.8px;
  flex-shrink: 0;
}
.filter-pill {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.09);
  color: rgba(238,242,255,0.55);
  font-family: 'DM Sans', sans-serif;
  font-size: 11px; font-weight: 500;
  padding: 3px 10px; border-radius: 20px;
  cursor: pointer; transition: all 0.15s;
  white-space: nowrap; flex-shrink: 0;
}
.filter-pill:hover { background: rgba(255,255,255,0.12); color: white; }
.filter-pill.active { background: var(--primary-light); border-color: transparent; color: white; }
.filter-sep { width: 1px; height: 16px; background: rgba(255,255,255,0.08); flex-shrink: 0; margin: 0 2px; }

/* Bar 3 — Status (darkest bar) */
.status-bar {
  background: var(--primary-dark);
  padding: 6px 20px;
  display: flex; align-items: center; justify-content: space-between;
  font-size: 11px;
}
.status-stats { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.stat-item { display: flex; align-items: center; gap: 5px; color: rgba(238,242,255,0.35); }
.stat-num { font-size: 13px; font-weight: 600; color: rgba(238,242,255,0.8); }
.stat-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.2); }
.stat-dot.complete { background: var(--accent-c); }
.stat-dot.progress { background: var(--accent-b); }
.stat-dot.blocked  { background: var(--accent-a); }

.sync-status { display: flex; align-items: center; gap: 5px; white-space: nowrap; }
.sync-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.2); }
.sync-dot.live    { background: var(--accent-c); }
.sync-dot.offline { background: var(--accent-b); }
.sync-dot.error   { background: var(--accent-a); }
#sync-label { font-size: 10px; color: rgba(238,242,255,0.3); }

/* ── MAIN ───────────────────────────────────────────────────── */
.main { padding: 20px 20px 80px; max-width: 1600px; margin: 0 auto; }
.view { display: none; }
.view.active { display: block; }

/* ── PIPELINE VIEW ──────────────────────────────────────────── */
.pipeline-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 12px; gap: 12px; flex-wrap: wrap;
}
.pipeline-count { font-size: 12px; color: var(--text-soft); }
.pipeline-count strong { color: var(--text); font-weight: 600; }
.pipeline-search {
  background: white; border: 2px solid var(--border);
  border-radius: 8px; padding: 6px 12px;
  font-family: 'DM Sans', sans-serif; font-size: 12px; color: var(--text);
  width: 220px; outline: none; transition: border-color 0.15s;
}
.pipeline-search:focus { border-color: var(--primary-light); }
.pipeline-search::placeholder { color: var(--text-soft); }

.table-wrap {
  overflow-x: auto; border-radius: 12px;
  border: 2px solid var(--border); background: white;
  box-shadow: 0 1px 4px rgba(0,0,0,0.05);
}
.pipeline-table { width: 100%; border-collapse: collapse; font-size: 12px; }

/* Table header */
.pipeline-table thead tr { background: var(--primary); }
.pipeline-table th {
  padding: 10px 10px; text-align: left;
  font-size: 9px; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.6px;
  color: rgba(238,242,255,0.45);
  white-space: nowrap;
  border-right: 1px solid rgba(255,255,255,0.05);
}
.pipeline-table th:first-child {
  position: sticky; left: 0; z-index: 3;
  background: var(--primary);
  min-width: 180px; max-width: 220px;
  color: rgba(238,242,255,0.65);
}
.pipeline-table th.step-col {
  text-align: center; min-width: 58px;
  padding: 8px 6px;
}
.th-snum { display: block; font-size: 13px; font-weight: 700; color: white; margin-bottom: 1px; }
.th-sname { display: block; font-size: 8px; color: rgba(238,242,255,0.35); letter-spacing: 0.3px; }
.th-owner { display: block; font-size: 8px; color: rgba(238,242,255,0.2); margin-top: 1px; }

/* Rows */
.pipeline-table tbody tr { border-top: 1px solid var(--cream-dark); transition: background 0.08s; }
.pipeline-table tbody tr:hover { background: #F8F5EF; }
.pipeline-table td {
  padding: 8px 10px; vertical-align: middle;
  border-right: 1px solid var(--cream-dark);
}
.pipeline-table td:first-child {
  position: sticky; left: 0; z-index: 1;
  background: white;
  border-right: 2px solid var(--border);
  max-width: 220px;
}
.pipeline-table tbody tr:hover td:first-child { background: #F8F5EF; }

/* Artist cell */
.artist-cell { display: flex; align-items: center; gap: 8px; }
.artist-link {
  font-weight: 500; color: var(--text);
  text-decoration: none; transition: color 0.1s;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.artist-link:hover { color: var(--primary-light); text-decoration: underline; }

/* Tier tags */
.tier-tag {
  display: inline-flex; align-items: center;
  font-size: 9px; font-weight: 700;
  padding: 2px 6px; border-radius: 8px;
  text-transform: uppercase; letter-spacing: 0.4px;
  white-space: nowrap; flex-shrink: 0;
}
.tier-headliner    { background: var(--tier-headliner-bg); color: var(--tier-headliner-col); }
.tier-sub-headliner { background: var(--tier-sub-bg); color: var(--tier-sub-col); }
.tier-support      { background: var(--tier-support-bg); color: var(--tier-support-col); }
.tier-local-act    { background: var(--tier-local-bg); color: var(--tier-local-col); }

/* Origin tags */
.origin-int   { background: var(--origin-int-bg);   color: var(--origin-int-col); }
.origin-ro    { background: var(--origin-ro-bg);    color: var(--origin-ro-col); }
.origin-local { background: var(--origin-local-bg); color: var(--origin-local-col); }

/* Lead avatar bubble */
.lead-avatar {
  width: 22px; height: 22px; border-radius: 50%;
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 8px; font-weight: 700; color: white; flex-shrink: 0;
}

/* Step status cells */
.step-cell { text-align: center; padding: 6px 4px !important; }
.step-dot {
  width: 18px; height: 18px; border-radius: 50%;
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 9px; font-weight: 700;
  position: relative; cursor: default;
}
.step-dot.s0 { background: var(--cream-dark); color: var(--text-soft); }
.step-dot.s1 { background: var(--accent-b-light); color: var(--accent-b); border: 1.5px solid var(--accent-b); }
.step-dot.s2 { background: var(--accent-c-light); color: var(--accent-c); }
.step-dot.s3 { background: var(--accent-a-light); color: var(--accent-a); }
/* Tooltip */
.step-dot:hover::after {
  content: attr(data-tip);
  position: absolute; bottom: calc(100% + 6px); left: 50%;
  transform: translateX(-50%);
  background: var(--primary); color: white;
  font-size: 9px; padding: 3px 8px; border-radius: 4px;
  white-space: nowrap; z-index: 20; pointer-events: none;
  font-weight: 400;
}

/* Boolean cells */
.bool-cell { text-align: center; }
.bool-yes { color: var(--accent-c); font-weight: 700; font-size: 13px; }
.bool-no  { color: var(--accent-a); font-weight: 700; font-size: 13px; }

/* Party size cell */
.party-cell { text-align: center; font-weight: 600; }
.party-cell.miss { color: var(--accent-a); }

/* Progress bar on artist row — last column */
.prog-wrap { display: flex; gap: 2px; align-items: center; }
.prog-seg {
  height: 4px; flex: 1; border-radius: 2px;
  background: var(--cream-dark);
}
.prog-seg.s1 { background: var(--accent-b); }
.prog-seg.s2 { background: var(--accent-c); }
.prog-seg.s3 { background: var(--accent-a); }

/* ── BLOCKERS VIEW ──────────────────────────────────────────── */
.blockers-hd {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 18px; gap: 12px; flex-wrap: wrap;
}
.blockers-title {
  font-family: 'Playfair Display', serif;
  font-size: 20px; color: var(--text);
}
.blockers-total { font-size: 12px; color: var(--text-soft); }

.blocker-card {
  background: white; border: 2px solid var(--border);
  border-radius: 12px; margin-bottom: 10px; overflow: hidden;
}
.blocker-card-hd {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 18px; cursor: pointer; transition: background 0.1s;
  user-select: none;
}
.blocker-card-hd:hover { background: #FAFAF8; }
.blocker-card.open .blocker-card-hd { border-bottom: 1px solid var(--border); }

.blocker-left { display: flex; align-items: center; gap: 12px; }
.blocker-icon {
  width: 34px; height: 34px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center; font-size: 15px;
}
.blocker-icon.red   { background: var(--accent-a-light); }
.blocker-icon.amber { background: var(--accent-b-light); }
.blocker-icon.gray  { background: var(--cream-dark); }

.blocker-name { font-size: 13px; font-weight: 600; color: var(--text); }
.blocker-desc { font-size: 11px; color: var(--text-soft); margin-top: 1px; }

.blocker-right { display: flex; align-items: center; gap: 10px; }
.blocker-badge {
  font-size: 11px; font-weight: 700;
  padding: 2px 9px; border-radius: 10px;
}
.blocker-badge.red   { background: var(--accent-a-light); color: var(--accent-a); }
.blocker-badge.amber { background: var(--accent-b-light); color: var(--accent-b); }
.blocker-badge.gray  { background: var(--cream-dark); color: var(--text-soft); }
.blocker-arrow { color: var(--text-soft); font-size: 11px; transition: transform 0.2s; }
.blocker-card.open .blocker-arrow { transform: rotate(180deg); }

.blocker-list { display: none; }
.blocker-card.open .blocker-list { display: block; }

.blocker-row {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 18px;
  border-bottom: 1px solid var(--cream-dark);
  font-size: 12px;
}
.blocker-row:last-child { border-bottom: none; }
.blocker-row-name { flex: 1; font-weight: 500; color: var(--text); }
.blocker-row-meta { display: flex; align-items: center; gap: 8px; }
.monday-link {
  font-size: 10px; color: var(--primary-light);
  text-decoration: none; font-weight: 600;
  padding: 2px 8px;
  border: 1px solid var(--primary-pale);
  border-radius: 4px; background: var(--primary-pale);
  transition: all 0.1s;
}
.monday-link:hover { background: var(--primary-light); color: white; border-color: transparent; }
.lead-name-small { font-size: 10px; color: var(--text-soft); }

/* ── BY LEAD VIEW ───────────────────────────────────────────── */
.bylead-hd {
  display: flex; align-items: baseline; justify-content: space-between;
  margin-bottom: 18px;
}
.bylead-title {
  font-family: 'Playfair Display', serif;
  font-size: 20px; color: var(--text);
}

.bylead-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
}
@media (max-width: 900px) { .bylead-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px) { .bylead-grid { grid-template-columns: 1fr; } }

.lead-card {
  background: white; border: 2px solid var(--border);
  border-radius: 12px; overflow: hidden;
}
.lead-card-hd {
  background: var(--primary);
  padding: 16px 18px;
  display: flex; align-items: center; gap: 12px;
}
.lead-avatar-lg {
  width: 40px; height: 40px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 700;
  background: rgba(255,255,255,0.88);
  flex-shrink: 0;
}
.lead-card-name {
  font-family: 'Playfair Display', serif;
  font-size: 15px; color: white;
}
.lead-card-role { font-size: 10px; color: rgba(255,255,255,0.4); margin-top: 1px; }

.lead-stats {
  display: grid; grid-template-columns: repeat(3, 1fr);
  border-bottom: 1px solid var(--border);
}
.lead-stat {
  padding: 10px 12px; text-align: center;
  border-right: 1px solid var(--border);
}
.lead-stat:last-child { border-right: none; }
.lead-stat-num { font-size: 20px; font-weight: 700; color: var(--text); line-height: 1; }
.lead-stat-num.green { color: var(--accent-c); }
.lead-stat-num.red   { color: var(--accent-a); }
.lead-stat-num.amber { color: var(--accent-b); }
.lead-stat-lbl { font-size: 9px; color: var(--text-soft); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 3px; }

/* Artist rows inside lead card */
.lead-artist-item {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 14px;
  border-bottom: 1px solid var(--cream-dark);
  font-size: 11px; transition: background 0.08s; cursor: default;
}
.lead-artist-item:last-child { border-bottom: none; }
.lead-artist-item:hover { background: #FAFAF8; }
.lead-artist-name { flex: 1; font-weight: 500; color: var(--text); }

.mini-steps { display: flex; gap: 2px; }
.mini-step { width: 8px; height: 8px; border-radius: 2px; background: var(--cream-dark); }
.mini-step.s1 { background: var(--accent-b); }
.mini-step.s2 { background: var(--accent-c); }
.mini-step.s3 { background: var(--accent-a); }

.lead-row-link {
  font-size: 10px; color: var(--primary-light);
  text-decoration: none; font-weight: 600;
  opacity: 0; transition: opacity 0.1s; padding: 0 2px;
}
.lead-artist-item:hover .lead-row-link { opacity: 1; }

.lead-show-more {
  padding: 8px 14px; text-align: center;
  font-size: 11px; color: var(--primary-light);
  cursor: pointer; border-top: 1px solid var(--border);
  background: #FAFAF8; transition: background 0.1s;
  font-weight: 500;
}
.lead-show-more:hover { background: var(--cream-dark); }

/* ── SETTINGS MODAL ─────────────────────────────────────────── */
.overlay {
  position: fixed; inset: 0;
  background: rgba(15, 30, 53, 0.72);
  backdrop-filter: blur(4px);
  z-index: 200; display: none;
  align-items: center; justify-content: center; padding: 20px;
}
.overlay.open { display: flex; }
.modal {
  background: white; border-radius: 16px;
  width: 100%; max-width: 540px;
  box-shadow: 0 24px 64px rgba(0,0,0,0.28);
  max-height: 90vh; overflow-y: auto;
}
.modal-hd {
  background: var(--primary);
  padding: 18px 24px;
  display: flex; align-items: center; justify-content: space-between;
  position: sticky; top: 0;
}
.modal-title {
  font-family: 'Playfair Display', serif;
  font-size: 17px; color: white;
}
.modal-close {
  background: rgba(255,255,255,0.1); border: none; color: white;
  font-size: 14px; width: 28px; height: 28px; border-radius: 50%;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: background 0.15s;
}
.modal-close:hover { background: rgba(255,255,255,0.2); }

.modal-body { padding: 24px; }
.modal-sec { margin-bottom: 24px; }
.modal-sec-title {
  font-size: 10px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.9px; color: var(--text-soft);
  padding-bottom: 8px; border-bottom: 1px solid var(--border);
  margin-bottom: 14px;
}
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.form-field { margin-bottom: 10px; }
.form-lbl { font-size: 11px; font-weight: 600; color: var(--text-mid); display: block; margin-bottom: 4px; }
.form-input {
  width: 100%; border: 2px solid var(--border); border-radius: 8px;
  padding: 7px 10px;
  font-family: 'DM Sans', sans-serif; font-size: 12px; color: var(--text);
  outline: none; transition: border-color 0.15s;
}
.form-input:focus { border-color: var(--primary-light); }
.form-hint { font-size: 10px; color: var(--text-soft); margin-top: 3px; line-height: 1.4; }

.modal-ft {
  padding: 14px 24px;
  border-top: 1px solid var(--border);
  display: flex; gap: 8px; justify-content: flex-end;
  background: #FAFAF8; position: sticky; bottom: 0;
}
.btn-save {
  background: var(--primary); color: white; border: none;
  font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 600;
  padding: 8px 20px; border-radius: 8px; cursor: pointer; transition: background 0.15s;
}
.btn-save:hover { background: var(--primary-mid); }
.btn-cancel {
  background: var(--cream-dark); color: var(--text); border: none;
  font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500;
  padding: 8px 16px; border-radius: 8px; cursor: pointer; transition: background 0.15s;
}
.btn-cancel:hover { background: var(--border); }

/* ── EMPTY STATE ────────────────────────────────────────────── */
.empty {
  text-align: center; padding: 60px 20px;
  color: var(--text-soft);
}
.empty-icon { font-size: 30px; margin-bottom: 12px; }
.empty h3 { font-size: 14px; font-weight: 600; color: var(--text-mid); margin-bottom: 6px; }
.empty p { font-size: 12px; }

/* ── ARTIST PANEL ───────────────────────────────────────────── */
.panel-backdrop {
  position: fixed; inset: 0;
  background: rgba(15,30,53,0.45);
  backdrop-filter: blur(2px);
  z-index: 150;
  opacity: 0; pointer-events: none;
  transition: opacity 0.2s;
}
.panel-backdrop.open { opacity: 1; pointer-events: all; }

.artist-panel {
  position: fixed; top: 0; right: 0; bottom: 0;
  width: 500px; max-width: 96vw;
  background: var(--cream);
  z-index: 160;
  display: flex; flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.25s cubic-bezier(0.22,1,0.36,1);
  box-shadow: -8px 0 40px rgba(0,0,0,0.18);
}
.artist-panel.open { transform: translateX(0); }

/* Panel header */
.panel-hd {
  background: var(--primary);
  padding: 16px 18px 14px;
  flex-shrink: 0;
}
.panel-hd-top {
  display: flex; align-items: flex-start; justify-content: space-between; gap: 10px;
  margin-bottom: 10px;
}
.panel-artist-name {
  font-family: 'Playfair Display', serif;
  font-size: 20px; color: white; line-height: 1.15;
}
.panel-close {
  background: rgba(255,255,255,0.1); border: none; color: white;
  width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
  font-size: 13px; cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: background 0.15s; margin-top: 2px;
}
.panel-close:hover { background: rgba(255,255,255,0.22); }

.panel-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 10px; }

.panel-meta {
  display: flex; gap: 14px; flex-wrap: wrap;
}
.panel-meta-item {
  display: flex; align-items: center; gap: 5px;
  font-size: 11px; color: rgba(238,242,255,0.5);
}
.panel-meta-item strong { color: rgba(238,242,255,0.85); font-weight: 600; }
.panel-monday-link {
  font-size: 10px; font-weight: 600;
  background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
  color: rgba(238,242,255,0.7); padding: 3px 10px; border-radius: 5px;
  text-decoration: none; transition: all 0.12s; white-space: nowrap;
}
.panel-monday-link:hover { background: rgba(255,255,255,0.2); color: white; }

/* Panel data strip */
.panel-strip {
  background: var(--primary-dark);
  padding: 8px 18px;
  display: flex; gap: 0; flex-shrink: 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.panel-strip-item {
  flex: 1; text-align: center;
  padding: 4px 6px;
  border-right: 1px solid rgba(255,255,255,0.06);
}
.panel-strip-item:last-child { border-right: none; }
.panel-strip-val {
  font-size: 13px; font-weight: 700;
  display: block; line-height: 1;
  margin-bottom: 3px;
}
.panel-strip-val.yes  { color: var(--accent-c); }
.panel-strip-val.no   { color: var(--accent-a); }
.panel-strip-val.num  { color: rgba(238,242,255,0.85); }
.panel-strip-val.dash { color: rgba(238,242,255,0.2); }
.panel-strip-lbl {
  font-size: 8px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.5px; color: rgba(238,242,255,0.25);
  display: block;
}

/* Panel body scroll */
.panel-body {
  flex: 1; overflow-y: auto; padding: 14px 0 40px;
}
.panel-body::-webkit-scrollbar { width: 4px; }
.panel-body::-webkit-scrollbar-track { background: transparent; }
.panel-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* Step sections */
.step-section {
  border-bottom: 1px solid var(--border);
}
.step-section-hd {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 18px; cursor: pointer;
  user-select: none; transition: background 0.1s;
}
.step-section-hd:hover { background: rgba(0,0,0,0.03); }

.step-num-badge {
  width: 22px; height: 22px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700;
  flex-shrink: 0;
}
.step-num-badge.done    { background: var(--accent-c-light); color: var(--accent-c); }
.step-num-badge.current { background: var(--primary); color: white; }
.step-num-badge.past    { background: var(--cream-dark); color: var(--text-soft); }

.step-section-name {
  flex: 1; font-size: 12px; font-weight: 600; color: var(--text);
}
.step-section-name .step-owner-badge {
  display: inline-block; font-size: 8px; font-weight: 700;
  padding: 1px 5px; border-radius: 4px; margin-left: 5px;
  text-transform: uppercase; letter-spacing: 0.4px;
  vertical-align: middle;
}
.step-owner-badge.ec    { background: var(--primary-pale); color: var(--primary-light); }
.step-owner-badge.tm    { background: var(--accent-b-light); color: var(--accent-b); }

.step-section-right { display: flex; align-items: center; gap: 6px; }
.step-pending-badge {
  font-size: 9px; font-weight: 700;
  padding: 2px 7px; border-radius: 8px;
  background: var(--accent-b-light); color: var(--accent-b);
}
.step-pending-badge.red { background: var(--accent-a-light); color: var(--accent-a); }
.step-done-badge {
  font-size: 9px; font-weight: 700;
  padding: 2px 7px; border-radius: 8px;
  background: var(--accent-c-light); color: var(--accent-c);
}
.step-toggle-arrow { font-size: 10px; color: var(--text-soft); transition: transform 0.18s; }
.step-section.expanded .step-toggle-arrow { transform: rotate(180deg); }

/* Action list */
.action-list { display: none; padding: 2px 0 8px; }
.step-section.expanded .action-list { display: block; }

.action-item {
  display: flex; align-items: flex-start; gap: 10px;
  padding: 6px 18px 6px 18px;
  transition: background 0.1s; position: relative;
  cursor: pointer;
}
.action-item:hover { background: rgba(0,0,0,0.025); }

/* Overdue = unticked item from a PAST step */
.action-item.overdue {
  background: var(--accent-b-light);
  border-left: 3px solid var(--accent-b);
  padding-left: 15px;
}
.action-item.overdue:hover { background: #fef0b0; }

/* The checkbox */
.action-check {
  width: 16px; height: 16px; border-radius: 4px; flex-shrink: 0;
  border: 2px solid var(--border-dark); background: white;
  display: flex; align-items: center; justify-content: center;
  margin-top: 1px; transition: all 0.12s; pointer-events: none;
}
.action-item.checked .action-check {
  background: var(--accent-c); border-color: var(--accent-c);
}
.action-item.checked .action-check::after {
  content: '✓'; font-size: 9px; font-weight: 700; color: white;
}
.action-item.overdue .action-check { border-color: var(--accent-b); }

.action-label {
  font-size: 12px; color: var(--text-mid); line-height: 1.45; flex: 1;
}
.action-item.checked .action-label {
  color: var(--text-soft); text-decoration: line-through;
}
.action-item.overdue .action-label { color: var(--text); font-weight: 500; }

.action-owner {
  font-size: 9px; font-weight: 600; flex-shrink: 0; margin-top: 2px;
  padding: 1px 5px; border-radius: 4px; text-transform: uppercase;
}
.action-owner.ec { background: var(--primary-pale); color: var(--primary-light); }
.action-owner.tm { background: var(--accent-b-light); color: var(--accent-b); }

/* Section progress bar */
.step-progress-bar {
  height: 2px; background: var(--cream-dark); margin: 0 18px 6px;
}
.step-progress-fill { height: 100%; background: var(--accent-c); border-radius: 1px; transition: width 0.3s; }

/* Action source badge */
.action-source {
  font-size: 8px; font-weight: 700; letter-spacing: 0.4px;
  padding: 1px 5px; border-radius: 4px; text-transform: uppercase;
  flex-shrink: 0; margin-top: 2px; white-space: nowrap;
}
.action-source.monday { background: var(--accent-d-light); color: var(--accent-d); }
.action-source.email  { background: #F0E6FF; color: #6B2FA0; }
.action-source.manual { background: var(--cream-dark); color: var(--text-soft); }

/* Conflict state — Monday says ✓ but user manually unticked */
.action-item.conflict {
  background: #FFF8E1;
  border-left: 3px solid #E6A817;
  padding-left: 15px;
}
.action-item.conflict:hover { background: #FFF3CC; }
.action-conflict-icon {
  font-size: 10px; flex-shrink: 0; margin-top: 2px;
  cursor: help; color: #B87010;
}

/* Panel legend */
.panel-legend {
  display: flex; gap: 8px; align-items: center;
  padding: 7px 18px; border-bottom: 1px solid var(--border);
  background: #FAFAF8; flex-wrap: wrap;
}
.panel-legend-item { display: flex; align-items: center; gap: 4px; font-size: 10px; color: var(--text-soft); }

</style>
</head>
<body>

<!-- ── LOADER ────────────────────────────────────────────────── -->
<div id="loader">
  <div class="spin"></div>
  <p>Syncing with Monday.com…</p>
</div>

<!-- ── APP HEADER ────────────────────────────────────────────── -->
<header class="app-header">

  <!-- Bar 1: Identity -->
  <div class="header-bar">
    <div class="header-identity">
      <span class="header-title">Hospitality</span>
      <span class="header-subtitle" id="event-subtitle">Electric Castle · EC12</span>
    </div>
    <div class="header-actions">
      <button class="header-btn" onclick="refreshData()">↻ Refresh</button>
      <button class="header-btn accent" onclick="openSettings()">⚙ Settings</button>
    </div>
  </div>

  <!-- Bar 2: View tabs + filters -->
  <div class="context-bar">
    <div class="view-tabs">
      <button class="view-tab active" data-view="pipeline">Pipeline</button>
      <button class="view-tab" data-view="blockers">Blockers</button>
      <button class="view-tab" data-view="bylead">By Lead</button>
    </div>
    <div class="filter-row">
      <span class="filter-label">Tier</span>
      <button class="filter-pill active" data-filter="tier" data-val="all">All</button>
      <button class="filter-pill" data-filter="tier" data-val="Headliner">Headliner</button>
      <button class="filter-pill" data-filter="tier" data-val="Sub-headliner">Sub</button>
      <button class="filter-pill" data-filter="tier" data-val="Support">Support</button>
      <button class="filter-pill" data-filter="tier" data-val="Local Act">Local</button>
      <div class="filter-sep"></div>
      <span class="filter-label">Lead</span>
      <button class="filter-pill active" data-filter="lead" data-val="all">All</button>
      <span id="lead-pills"></span>
      <div class="filter-sep"></div>
      <span class="filter-label">Status</span>
      <button class="filter-pill active" data-filter="status" data-val="all">All</button>
      <button class="filter-pill" data-filter="status" data-val="blocked">Blocked</button>
      <button class="filter-pill" data-filter="status" data-val="complete">Complete</button>
      <button class="filter-pill" data-filter="status" data-val="idle">Not Started</button>
      <div class="filter-sep"></div>
      <span class="filter-label">Origin</span>
      <button class="filter-pill active" data-filter="origin" data-val="all">All</button>
      <button class="filter-pill" data-filter="origin" data-val="Int">INT</button>
      <button class="filter-pill" data-filter="origin" data-val="RO">RO</button>
      <button class="filter-pill" data-filter="origin" data-val="Local">Local</button>
      <div class="filter-sep"></div>
      <span class="filter-label">Booked By</span>
      <button class="filter-pill active" data-filter="bookedBy" data-val="all">All</button>
      <span id="bookedby-pills"></span>
    </div>
  </div>

  <!-- Bar 3: Sync / stats -->
  <div class="status-bar">
    <div class="status-stats">
      <div class="stat-item"><div class="stat-dot"></div><span class="stat-num" id="s-total">—</span>&nbsp;artists</div>
      <div class="stat-item"><div class="stat-dot complete"></div><span class="stat-num" id="s-complete">—</span>&nbsp;complete</div>
      <div class="stat-item"><div class="stat-dot progress"></div><span class="stat-num" id="s-progress">—</span>&nbsp;in progress</div>
      <div class="stat-item"><div class="stat-dot blocked"></div><span class="stat-num" id="s-blocked">—</span>&nbsp;blocked</div>
      <div class="stat-item"><div class="stat-dot"></div><span class="stat-num" id="s-idle">—</span>&nbsp;not started</div>
    </div>
    <div class="sync-status">
      <div class="sync-dot" id="sync-dot"></div>
      <span id="sync-label">Loading…</span>
    </div>
  </div>

</header>

<!-- ── MAIN ───────────────────────────────────────────────────── -->
<div class="main">

  <!-- Pipeline View -->
  <div class="view active" id="view-pipeline">
    <div class="pipeline-toolbar">
      <p class="pipeline-count"><strong id="vis-count">—</strong> artists shown</p>
      <input class="pipeline-search" id="search-input" type="text"
        placeholder="Search artists…" oninput="handleSearch(this.value)"/>
    </div>
    <div class="table-wrap">
      <table class="pipeline-table">
        <thead>
          <tr>
            <th>Artist</th>
            <th>Tier</th>
            <th>Lead</th>
            <th class="step-col"><span class="th-snum">0</span><span class="th-sname">KO</span><span class="th-owner">EC</span></th>
            <th class="step-col"><span class="th-snum">1</span><span class="th-sname">Intro</span><span class="th-owner">EC</span></th>
            <th class="step-col"><span class="th-snum">2</span><span class="th-sname">TM Reply</span><span class="th-owner">TM</span></th>
            <th class="step-col"><span class="th-snum">3</span><span class="th-sname">Confirm</span><span class="th-owner">EC</span></th>
            <th class="step-col"><span class="th-snum">4</span><span class="th-sname">Travel</span><span class="th-owner">TM</span></th>
            <th class="step-col"><span class="th-snum">5</span><span class="th-sname">On-site</span><span class="th-owner">EC</span></th>
            <th class="step-col"><span class="th-snum">6</span><span class="th-sname">TM Final</span><span class="th-owner">TM</span></th>
            <th class="step-col"><span class="th-snum">7</span><span class="th-sname">Handover</span><span class="th-owner">EC</span></th>
            <th style="text-align:center;min-width:52px;">Rider</th>
            <th style="text-align:center;min-width:46px;">Party</th>
            <th style="text-align:center;min-width:52px;">Hotel</th>
            <th style="text-align:center;min-width:54px;">Origin</th>
            <th style="min-width:90px;">Booked By</th>
          </tr>
        </thead>
        <tbody id="pipeline-body"></tbody>
      </table>
    </div>
  </div>

  <!-- Blockers View -->
  <div class="view" id="view-blockers">
    <div class="blockers-hd">
      <h2 class="blockers-title">Blockers</h2>
      <span class="blockers-total" id="blockers-total"></span>
    </div>
    <div id="blockers-container"></div>
  </div>

  <!-- By Lead View -->
  <div class="view" id="view-bylead">
    <div class="bylead-hd">
      <h2 class="bylead-title">By Advancing Lead</h2>
    </div>
    <div class="bylead-grid" id="bylead-grid"></div>
  </div>

</div>

<!-- ── ARTIST DETAIL PANEL ────────────────────────────────────── -->
<div class="panel-backdrop" id="panel-backdrop" onclick="closePanel()"></div>
<aside class="artist-panel" id="artist-panel">
  <div class="panel-hd">
    <div class="panel-hd-top">
      <span class="panel-artist-name" id="panel-name">—</span>
      <button class="panel-close" onclick="closePanel()">✕</button>
    </div>
    <div class="panel-tags" id="panel-tags"></div>
    <div class="panel-meta" id="panel-meta"></div>
  </div>
  <div class="panel-strip" id="panel-strip"></div>
  <div class="panel-body" id="panel-body"></div>
</aside>

<!-- ── SETTINGS MODAL ─────────────────────────────────────────── -->
<div class="overlay" id="settings-overlay">
  <div class="modal">
    <div class="modal-hd">
      <span class="modal-title">Dashboard Settings</span>
      <button class="modal-close" onclick="closeSettings()">✕</button>
    </div>
    <div class="modal-body">

      <div class="modal-sec">
        <div class="modal-sec-title">Monday.com Connection</div>
        <div class="form-field">
          <label class="form-lbl">API Key</label>
          <input class="form-input" id="cfg-apikey" type="password" placeholder="eyJhbGci…"/>
          <p class="form-hint">Monday.com → Profile → Developers → My Access Tokens</p>
        </div>
        <div class="form-row">
          <div class="form-field">
            <label class="form-lbl">Board ID</label>
            <input class="form-input" id="cfg-boardid" type="text" placeholder="123456789"/>
            <p class="form-hint">In the URL: monday.com/boards/<strong>ID</strong></p>
          </div>
          <div class="form-field">
            <label class="form-lbl">Workspace URL</label>
            <input class="form-input" id="cfg-workspace" type="text" placeholder="yourorg.monday.com"/>
            <p class="form-hint">Domain only — for item links</p>
          </div>
        </div>
      </div>

      <div class="modal-sec">
        <div class="modal-sec-title">Connected Board IDs</div>
        <p style="font-size:11px;color:var(--text-soft);margin-bottom:14px;">
          Used to evaluate action-level field conditions. Find board IDs in the Monday.com URL when viewing that board.
        </p>
        <div class="form-row">
          <div class="form-field"><label class="form-lbl">Artist Advancing Tracker</label><input class="form-input" id="bid-artist" type="text" placeholder="= main Board ID above"/></div>
          <div class="form-field"><label class="form-lbl">Accommodation</label><input class="form-input" id="bid-accommodation" type="text" placeholder="Board ID"/></div>
          <div class="form-field"><label class="form-lbl">Flights</label><input class="form-input" id="bid-flights" type="text" placeholder="Board ID"/></div>
          <div class="form-field"><label class="form-lbl">Transfers</label><input class="form-input" id="bid-transfers" type="text" placeholder="Board ID"/></div>
          <div class="form-field"><label class="form-lbl">Team Members</label><input class="form-input" id="bid-team" type="text" placeholder="Board ID"/></div>
          <div class="form-field"><label class="form-lbl">Stages</label><input class="form-input" id="bid-stages" type="text" placeholder="Board ID"/></div>
          <div class="form-field"><label class="form-lbl">Dressing Rooms</label><input class="form-input" id="bid-dressing_rooms" type="text" placeholder="Board ID"/></div>
        </div>
      </div>

      <div class="modal-sec">
        <div class="modal-sec-title">Column ID Mapping</div>
        <p style="font-size:11px;color:var(--text-soft);margin-bottom:14px;">
          Find column IDs in Monday.com by right-clicking any column header → Column Settings → Copy Column ID.
        </p>
        <div class="form-row">
          <div class="form-field">
            <label class="form-lbl">Tier (status/dropdown)</label>
            <input class="form-input" id="col-tier" type="text" placeholder="status"/>
          </div>
          <div class="form-field">
            <label class="form-lbl">Advancing Lead (people)</label>
            <input class="form-input" id="col-lead" type="text" placeholder="person"/>
          </div>
          <div class="form-field">
            <label class="form-lbl">Booked By (people)</label>
            <input class="form-input" id="col-bookedBy" type="text" placeholder="person1"/>
            <p class="form-hint">Links to team members board</p>
          </div>
          <div class="form-field">
            <label class="form-lbl">Artist Origin (status)</label>
            <input class="form-input" id="col-origin" type="text" placeholder="status9"/>
            <p class="form-hint">Values: Int / RO / Local</p>
          </div>
        </div>
        <div class="form-row">
          <div class="form-field"><label class="form-lbl">Step 0 — KO</label><input class="form-input" id="col-s0" type="text" placeholder="status_1"/></div>
          <div class="form-field"><label class="form-lbl">Step 1 — Intro Email</label><input class="form-input" id="col-s1" type="text" placeholder="status_2"/></div>
          <div class="form-field"><label class="form-lbl">Step 2 — TM Response</label><input class="form-input" id="col-s2" type="text" placeholder="status_3"/></div>
          <div class="form-field"><label class="form-lbl">Step 3 — Confirmations</label><input class="form-input" id="col-s3" type="text" placeholder="status_4"/></div>
          <div class="form-field"><label class="form-lbl">Step 4 — Travel Details</label><input class="form-input" id="col-s4" type="text" placeholder="status_5"/></div>
          <div class="form-field"><label class="form-lbl">Step 5 — On-site Intro</label><input class="form-input" id="col-s5" type="text" placeholder="status_6"/></div>
          <div class="form-field"><label class="form-lbl">Step 6 — TM Final</label><input class="form-input" id="col-s6" type="text" placeholder="status_7"/></div>
          <div class="form-field"><label class="form-lbl">Step 7 — Handover</label><input class="form-input" id="col-s7" type="text" placeholder="status_8"/></div>
          <div class="form-field"><label class="form-lbl">Rider Received (checkbox)</label><input class="form-input" id="col-rider" type="text" placeholder="checkbox"/></div>
          <div class="form-field"><label class="form-lbl">Party Size (numbers)</label><input class="form-input" id="col-party" type="text" placeholder="numbers"/></div>
          <div class="form-field"><label class="form-lbl">Hotel (text)</label><input class="form-input" id="col-hotel" type="text" placeholder="text"/></div>
          <div class="form-field"><label class="form-lbl">Dietary Confirmed (checkbox)</label><input class="form-input" id="col-dietary" type="text" placeholder="checkbox0"/></div>
        </div>
      </div>

      <div class="modal-sec">
        <div class="modal-sec-title">Display</div>
