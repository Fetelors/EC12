  if (condition === 'not_empty') return text !== '' && text !== '-';
  if (condition === 'checked') {
    try { return JSON.parse(rawCol.value || '{}')?.checked === 'true'; }
    catch { return text.toLowerCase() === 'v'; }
  }
  if (condition === 'has_relation') {
    try {
      const p = JSON.parse(rawCol.value || '{}');
      return Array.isArray(p?.linkedPulseIds) && p.linkedPulseIds.length > 0;
    } catch { return text !== '' && text !== '-'; }
  }
  if (condition.startsWith('equals:')) {
    return text.toLowerCase() === condition.slice(7).toLowerCase();
  }
  return false;
}

// ── RESOLVED TICK STATE ───────────────────────────────────────
// Returns { ticked, autoSource, conflict } for a single action.
// autoSource: 'monday' | 'email' | null (for manual actions autoSource is null)
// conflict:   true if user override disagrees with auto state
function resolveActionTick(artist, stepNum, actionIdx) {
  const action  = ACTION_STEPS[stepNum]?.actions[actionIdx];
  if (!action) return { ticked: false, autoSource: null, conflict: false };

  const key      = stepNum + '_' + actionIdx;
  const overrides = getOverrides(artist.id);
  const manTicks  = getManualTicks(artist.id);
  const emailMods = getEmailModules(artist.id);

  let autoTick = false;
  let autoSource = null;

  if (action.source === 'monday') {
    autoSource = 'monday';
    const rawCol = artist.rawColumns?.[action.columnId];
    autoTick = evalCondition(rawCol, action.condition);
  } else if (action.source === 'email') {
    autoSource = 'email';
    autoTick = !!(emailMods[action.emailModule]?.sent);
  }
  // source === 'manual': no autoTick

  const hasOverride = key in overrides && overrides[key] !== null;
  const effectiveTick = hasOverride ? overrides[key] : (autoSource ? autoTick : !!(manTicks[key]));
  const conflict = hasOverride && overrides[key] !== autoTick && autoSource !== null;

  return { ticked: effectiveTick, autoTick, autoSource, conflict, hasOverride };
}

// ── TOGGLE ACTION ─────────────────────────────────────────────
// Manual actions: writes to actions_[id].
// Auto-sourced actions: writes an override to overrides_[id].
// If override matches auto state exactly → clear the override (no conflict).
function toggleAction(artistId, stepNum, actionIdx) {
  const action   = ACTION_STEPS[stepNum]?.actions[actionIdx];
  if (!action) return;
  const artist   = ST.artists.find(a => a.id === artistId);
  const resolved = resolveActionTick(artist, stepNum, actionIdx);
  const newVal   = !resolved.ticked;
  const key      = stepNum + '_' + actionIdx;

  if (action.source === 'manual') {
    const ticks = getManualTicks(artistId);
    ticks[key] = newVal;
    localStorage.setItem('actions_' + artistId, JSON.stringify(ticks));
  } else {
    // Auto-sourced: write override; clear it if it matches auto state
    const overrides = getOverrides(artistId);
    if (newVal === resolved.autoTick) {
      delete overrides[key]; // no longer diverges — clear conflict
    } else {
      overrides[key] = newVal;
    }
    localStorage.setItem('overrides_' + artistId, JSON.stringify(overrides));
  }
  if (ST.panelArtist) renderPanel(ST.panelArtist);
}

// ── LEAD COLOURS ─────────────────────────────────────────────
const LEAD_PALETTE = ['#3D5A8A','#1A7A50','#7C4A8A','#B87010','#C85A45','#2558C9','#5A7A3A','#8A3A5A'];
const _leadColMap = {};
function leadColour(name) {
  if (!_leadColMap[name]) {
    _leadColMap[name] = LEAD_PALETTE[Object.keys(_leadColMap).length % LEAD_PALETTE.length];
  }
  return _leadColMap[name];
}
function initials(name) {
  return name.split(' ').map(p => p[0]).join('').toUpperCase().slice(0,2);
}

// ── MONDAY.COM API ────────────────────────────────────────────
async function fetchMonday() {
  if (!CFG.apiKey || !CFG.boardId) return null;

  // Collect all column IDs: summary-level cols + all action-level artist cols
  const summaryColIds = Object.values(CFG.cols).filter(Boolean);
  const actionColIds  = [];
  ACTION_STEPS.forEach(step => step.actions.forEach(act => {
    if (act.source === 'monday' && act.boardRef === 'artist' && act.columnId) {
      if (!actionColIds.includes(act.columnId)) actionColIds.push(act.columnId);
    }
  }));
  const allColIds = [...new Set([...summaryColIds, ...actionColIds])];

  const query = `{
    boards(ids: [${CFG.boardId}]) {
      items_page(limit: 500) {
        items {
          id
          name
          column_values(ids: ${JSON.stringify(allColIds)}) {
            id text value
          }
        }
      }
    }
  }`;

  try {
    const res = await fetch('https://api.monday.com/v2', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': CFG.apiKey,
        'API-Version': '2024-01'
      },
      body: JSON.stringify({ query })
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const json = await res.json();
    if (json.errors) throw new Error(json.errors[0].message);
    const items = json?.data?.boards?.[0]?.items_page?.items || [];
    return items.map(parseMondayItem);
  } catch (err) {
    console.warn('Monday.com fetch failed:', err.message);
    return null;
  }
}

function parseMondayItem(item) {
  const cv = {};
  (item.column_values || []).forEach(c => { cv[c.id] = c; });

  const statusVal = (colId) => {
    const t = (cv[colId]?.text || '').toLowerCase().trim();
    return STATUS_MAP.hasOwnProperty(t) ? STATUS_MAP[t] : 0;
  };
  const textVal  = (colId) => cv[colId]?.text || null;
  const numVal   = (colId) => { const n = parseInt(cv[colId]?.text); return isNaN(n) ? null : n; };
  const leadVal  = (colId) => {
    try {
      const p = JSON.parse(cv[colId]?.value || '{}');
      return p?.personsAndTeams?.[0]?.name || textVal(colId) || '—';
    } catch { return textVal(colId) || '—'; }
  };
  const hasRelation = (colId) => evalCondition(cv[colId], 'has_relation');
  const notEmpty    = (colId) => evalCondition(cv[colId], 'not_empty');

  return {
    id:         item.id,
    name:       item.name,
    tier:       textVal(CFG.cols.tier) || 'Support',
    lead:       leadVal(CFG.cols.lead),
    bookedBy:   leadVal(CFG.cols.bookedBy),
    origin:     textVal(CFG.cols.origin) || 'Int',
    steps:      [0,1,2,3,4,5,6,7].map(i => statusVal(CFG.cols['s'+i])),
    // Summary indicators (used for pipeline dots + blockers)
    rider:      notEmpty('files__1'),           // Initial Rider file uploaded
    partySize:  numVal('numbers'),              // A-Party
    hotel:      hasRelation('board_relation7'), // A Party Hotel linked
    dietary:    notEmpty('long_text02__1'),     // Allergies filled
    // Raw column values — used by resolveActionTick for action-level evaluation
    rawColumns: cv
  };
}

function mondayUrl(itemId) {
  if (!CFG.workspaceUrl || !CFG.boardId || !itemId) return '#';
  const base = CFG.workspaceUrl.replace(/^https?:\/\//, '');
  return `https://${base}/boards/${CFG.boardId}/items/${itemId}`;
}

// ── COMPUTED ──────────────────────────────────────────────────
function overallStatus(a) {
  if (a.steps.includes(3)) return 'blocked';
  if (a.steps[7] === 2)    return 'complete';
  if (a.steps.some(s => s > 0)) return 'in-progress';
  return 'idle';
}

function hasBlockers(a) {
  return !a.rider || a.partySize === null || !a.hotel || !a.dietary || a.steps.includes(3);
}

function stepsDone(a) {
  return a.steps.filter(s => s === 2).length;
}

// ── FILTERS ───────────────────────────────────────────────────
function applyFilters() {
  let r = ST.artists;
  if (ST.filters.tier     !== 'all') r = r.filter(a => a.tier === ST.filters.tier);
  if (ST.filters.lead     !== 'all') r = r.filter(a => a.lead === ST.filters.lead);
  if (ST.filters.origin   !== 'all') r = r.filter(a => a.origin === ST.filters.origin);
  if (ST.filters.bookedBy !== 'all') r = r.filter(a => a.bookedBy === ST.filters.bookedBy);
  if (ST.filters.status === 'blocked')  r = r.filter(a => overallStatus(a) === 'blocked');
  if (ST.filters.status === 'complete') r = r.filter(a => overallStatus(a) === 'complete');
  if (ST.filters.status === 'idle')     r = r.filter(a => overallStatus(a) === 'idle');
  if (ST.search) r = r.filter(a => a.name.toLowerCase().includes(ST.search.toLowerCase()));
  ST.filtered = r;
}

